    $srcTxt = New-Object System.Windows.Controls.TextBox
    [System.Windows.Controls.Grid]::SetColumn($srcTxt, 1); [void]$srcRow.Children.Add($srcTxt)
    $srcBrowse = New-Object System.Windows.Controls.Button
    $srcBrowse.Content = 'Browse...'; $srcBrowse.Margin = '6,0,0,0'
