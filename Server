    @{ Key='Dashboard';   Title='Dashboard';         Sub='System overview' }
    @{ Key='Diagnostics'; Title='Diagnostics';       Sub='Event logs, processes, services, hotfixes, health' }
    @{ Key='Diagnostics'; Title='Event logs';        Sub='Filter and export Windows event logs' }
