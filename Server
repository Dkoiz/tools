        $cmdConsole.Text.ClearLog()
        $cmdConsole.Text.AppendLog("# Invoke-Command on $($targets.Count) host(s):")
        $cmdConsole.Text.AppendLog("# $cmd`r`n")
        Set-ButtonBusy -Button $cmdRun -Busy $true -BusyText 'Running...'
        Invoke-Async -Script {
            param($targets, $cmd)
            $sb = [scriptblock]::Create($cmd)
            foreach ($t in $targets) {
                try {
                    $out = Invoke-Command -ComputerName $t -ScriptBlock $sb -ErrorAction Stop | Out-String
                    Write-Information "=== $t ===" -InformationAction Continue
                    foreach ($line in ($out -split "`r?`n")) { Write-Information $line -InformationAction Continue }
                } catch {
                    Write-Information "=== $t (ERROR) ===" -InformationAction Continue
                    Write-Information "  $($_.Exception.Message)" -InformationAction Continue
                }
            }
        } -Arguments @($targets, $cmd) `
          -OnProgress { param($l) $cmdConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            Set-ButtonBusy -Button $cmdRun -Busy $false
            Show-Toast -Message 'Done' -Kind Success
            Write-AuditLog -Action 'RemoteCommandBatch' -Target ($targets -join ',') -Details $cmd
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $cmdRun -Busy $false
            $cmdConsole.Text.AppendLog("# ERROR: $($e.Exception.Message)")
          }.GetNewClosure()
    }.GetNewClosure())

    $infoBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { return }
        Set-ButtonBusy -Button $infoBtn -Busy $true
        $infoGrid.ItemsSource = $null
        Invoke-Async -Script {
            param($targets)
            $out = foreach ($t in $targets) {
                try {
                    $info = Invoke-Command -ComputerName $t -ScriptBlock {
                        $os = Get-CimInstance Win32_OperatingSystem
                        $cs = Get-CimInstance Win32_ComputerSystem
                        $cpu = Get-CimInstance Win32_Processor | Select-Object -First 1
                        $c = Get-CimInstance Win32_LogicalDisk -Filter "DeviceID='C:'"
                        $up = (Get-Date) - $os.LastBootUpTime
                        [pscustomobject]@{
                            OS       = $os.Caption
                            Cores    = $cpu.NumberOfLogicalProcessors
                            RAMGB    = [math]::Round($cs.TotalPhysicalMemory/1GB,1)
                            FreeC    = if ($c) { "$([math]::Round($c.FreeSpace/1GB,0))GB" } else { 'n/a' }
                            LastBoot = $os.LastBootUpTime.ToString('yyyy-MM-dd HH:mm')
                            Uptime   = "$([int]$up.TotalDays)d $($up.Hours)h"
                        }
                    } -ErrorAction Stop
                    [pscustomobject]@{
                        Host=$t; OS=$info.OS; Uptime=$info.Uptime; Cores=$info.Cores
                        RAMGB=$info.RAMGB; FreeC=$info.FreeC; LastBoot=$info.LastBoot; Error=''
                    }
                } catch {
                    [pscustomobject]@{ Host=$t; OS=''; Uptime=''; Cores=''; RAMGB=''; FreeC=''; LastBoot=''; Error=$_.Exception.Message }
                }
            }
            $out
        } -Arguments @(,$targets) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $infoBtn -Busy $false
            $infoGrid.ItemsSource = $r
            Write-AuditLog -Action 'RemoteSystemInfo' -Target ($targets -join ',') -Details "$(@($r).Count) hosts"
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $infoBtn -Busy $false
            Show-Toast -Message "Gather failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }.GetNewClosure())

    $svcBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { return }
        $name = $svcName.Text.Trim()
        $action = $svcActionCombo.SelectedItem
        if (-not $name) { Show-Toast -Message 'Service name required' -Kind Warning; return }
        if ($action -ne 'Query' -and -not (Show-Confirm -Message "$action service '$name' on $($targets.Count) host(s)?" -Danger:($action -eq 'Stop'))) { return }
        $svcConsole.Text.ClearLog()
        $svcConsole.Text.AppendLog("# $action '$name' on $($targets.Count) host(s)")
        Set-ButtonBusy -Button $svcBtn -Busy $true
        Invoke-Async -Script {
            param($targets, $name, $action)
            foreach ($t in $targets) {
                try {
                    $r = Invoke-Command -ComputerName $t -ScriptBlock {
                        param($name, $action)
                        switch ($action) {
                            'Start'   { Start-Service -Name $name -ErrorAction Stop; (Get-Service $name).Status }
                            'Stop'    { Stop-Service  -Name $name -Force -ErrorAction Stop; (Get-Service $name).Status }
                            'Restart' { Restart-Service -Name $name -Force -ErrorAction Stop; (Get-Service $name).Status }
                            'Query'   { (Get-Service $name -ErrorAction Stop).Status }
                        }
                    } -ArgumentList $name, $action -ErrorAction Stop
                    Write-Information "[OK]   $t : $name -> $r" -InformationAction Continue
                } catch {
                    Write-Information "[FAIL] $t : $($_.Exception.Message)" -InformationAction Continue
                }
            }
        } -Arguments @($targets, $name, $action) `
          -OnProgress { param($l) $svcConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            Set-ButtonBusy -Button $svcBtn -Busy $false
            Show-Toast -Message 'Done' -Kind Success
            Write-AuditLog -Action "RemoteService$action" -Target ($targets -join ',') -Details $name
          }.GetNewClosure()
    }.GetNewClosure())

    $rebBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { return }
        if (-not (Show-Confirm -Message "Reboot $($targets.Count) host(s)? This is disruptive." -Title 'Confirm reboot' -ConfirmText 'Reboot' -Danger)) { return }
        $rebConsole.Text.ClearLog()
        Set-ButtonBusy -Button $rebBtn -Busy $true
        Invoke-Async -Script {
            param($targets)
            foreach ($t in $targets) {
                try { Restart-Computer -ComputerName $t -Force -ErrorAction Stop
                    Write-Information "[OK]   $t reboot initiated" -InformationAction Continue
                } catch {
                    Write-Information "[FAIL] $t $($_.Exception.Message)" -InformationAction Continue
                }
            }
        } -Arguments @(,$targets) `
          -OnProgress { param($l) $rebConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            Set-ButtonBusy -Button $rebBtn -Busy $false
            Write-AuditLog -Action 'RemoteReboot' -Target ($targets -join ',')
            Show-Toast -Message 'Reboot commands sent' -Kind Warning
          }.GetNewClosure()
    }.GetNewClosure())

    $shutBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { return }
        if (-not (Show-Confirm -Message "Shut down $($targets.Count) host(s)?" -Danger -ConfirmText 'Shutdown')) { return }
        $rebConsole.Text.ClearLog()
        Set-ButtonBusy -Button $shutBtn -Busy $true
        Invoke-Async -Script {
            param($targets)
            foreach ($t in $targets) {
                try { Stop-Computer -ComputerName $t -Force -ErrorAction Stop
                    Write-Information "[OK]   $t shutdown sent" -InformationAction Continue
                } catch {
                    Write-Information "[FAIL] $t $($_.Exception.Message)" -InformationAction Continue
                }
            }
        } -Arguments @(,$targets) `
          -OnProgress { param($l) $rebConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            Set-ButtonBusy -Button $shutBtn -Busy $false
            Write-AuditLog -Action 'RemoteShutdown' -Target ($targets -join ',')
          }.GetNewClosure()
    }.GetNewClosure())

    $srcBrowse.Add_Click({
        $dlg = New-Object Microsoft.Win32.OpenFileDialog
        if ($dlg.ShowDialog()) { $srcTxt.Text = $dlg.FileName }
    }.GetNewClosure())
    $copyBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { return }
        $src = $srcTxt.Text; $dst = $dstTxt.Text
        if (-not (Test-Path $src)) { Show-Toast -Message 'Source does not exist' -Kind Warning; return }
        if (-not $dst) { Show-Toast -Message 'Destination required' -Kind Warning; return }
        if (-not (Show-Confirm -Message "Copy '$src' to '$dst' on $($targets.Count) host(s)?")) { return }
        $copyConsole.Text.ClearLog()
        Set-ButtonBusy -Button $copyBtn -Busy $true -BusyText 'Copying...'
        Invoke-Async -Script {
            param($targets, $src, $dst)
            foreach ($t in $targets) {
                try {
                    $session = New-PSSession -ComputerName $t -ErrorAction Stop
                    Copy-Item -Path $src -Destination $dst -ToSession $session -Force -ErrorAction Stop
                    Remove-PSSession $session
                    Write-Information "[OK]   $t" -InformationAction Continue
                } catch {
                    Write-Information "[FAIL] $t $($_.Exception.Message)" -InformationAction Continue
                }
            }
        } -Arguments @($targets, $src, $dst) `
          -OnProgress { param($l) $copyConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            Set-ButtonBusy -Button $copyBtn -Busy $false
            Write-AuditLog -Action 'RemoteCopy' -Target ($targets -join ',') -Details "$src -> $dst"
            Show-Toast -Message 'Copy complete' -Kind Success
          }.GetNewClosure()
    }.GetNewClosure())

    # --- Break-glass admin: shared remote scriptblock & handlers --------------
    $bgRemoteAction = {
        param($targets, $pw, $disableAfter, $neverExp, $verifyOnly)

        foreach ($t in $targets) {
            try {
                $r = Invoke-Command -ComputerName $t -ErrorAction Stop -ArgumentList $pw, $disableAfter, $neverExp, $verifyOnly -ScriptBlock {
                    param($pw, $disableAfter, $neverExp, $verifyOnly)

                    # Safe Mode escape-hatch flag
                    $lsa = Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\Lsa' -ErrorAction SilentlyContinue
                    $safeModeOk = -not ($lsa.SafeModeBlockBuiltInAdmin -eq 1)

                    # Locate built-in admin by SID -500 (works across rename)
                    $name = $null; $enabledBefore = $null; $useAdsi = $false
                    if (Get-Command Get-LocalUser -ErrorAction SilentlyContinue) {
                        $u = Get-LocalUser | Where-Object { $_.SID.Value -like 'S-1-5-21-*-500' }
                        if ($u) { $name = $u.Name; $enabledBefore = $u.Enabled }
                    } else {
                        $useAdsi = $true
                    }
                    if (-not $name) {
                        # ADSI fallback (older OS or LocalAccounts module missing)
                        $useAdsi = $true
                        $comp = [ADSI]"WinNT://$env:COMPUTERNAME"
                        foreach ($child in $comp.Children) {
                            if ($child.SchemaClassName -eq 'User') {
                                $sid = (New-Object System.Security.Principal.SecurityIdentifier($child.objectSid.Value, 0)).Value
                                if ($sid -like '*-500') {
                                    $name = $child.Name.Value
                                    $enabledBefore = -not (($child.UserFlags.Value -band 0x2) -eq 0x2)
                                    break
                                }
                            }
                        }
                    }
                    if (-not $name) { throw 'Built-in Administrator (SID -500) not found' }

                    $passwordSet = $false; $enabledAfter = $enabledBefore
                    if (-not $verifyOnly) {
                        if ($useAdsi) {
                            $adsi = [ADSI]"WinNT://$env:COMPUTERNAME/$name,user"
                            $plain = [Runtime.InteropServices.Marshal]::PtrToStringAuto(
                                [Runtime.InteropServices.Marshal]::SecureStringToBSTR($pw))
                            $adsi.SetPassword($plain)
                            if ($neverExp) {
                                # 0x10000 = DONT_EXPIRE_PASSWORD
                                $adsi.UserFlags = $adsi.UserFlags.Value -bor 0x10000
                            }
                            if ($disableAfter) {
                                $adsi.UserFlags = $adsi.UserFlags.Value -bor 0x2
                            } else {
                                $adsi.UserFlags = $adsi.UserFlags.Value -band (-bnot 0x2)
                            }
                            $adsi.SetInfo()
                            $passwordSet = $true
                        } else {
                            Set-LocalUser -Name $name -Password $pw `
                                          -PasswordNeverExpires:$neverExp `
                                          -UserMayChangePassword:$false -ErrorAction Stop
                            $passwordSet = $true
                            if ($disableAfter) {
                                # net user bypasses "last enabled local admin" safety check
                                & net user $name /active:no | Out-Null
                                if ($LASTEXITCODE -ne 0) { throw "net user disable failed (exit $LASTEXITCODE)" }
                            } elseif (-not $enabledBefore) {
                                & net user $name /active:yes | Out-Null
                            }
                        }
                        $after = Get-LocalUser -Name $name -ErrorAction SilentlyContinue
                        if ($after) { $enabledAfter = $after.Enabled }
                    }

                    [pscustomobject]@{
                        Account       = $name
                        EnabledBefore = $enabledBefore
                        EnabledAfter  = $enabledAfter
                        PasswordSet   = $passwordSet
                        SafeModeOk    = $safeModeOk
                    }
                }
                Write-Information ("[OK]   {0,-25} {1} (was enabled={2}, now enabled={3}, safeMode={4})" -f $t, $r.Account, $r.EnabledBefore, $r.EnabledAfter, $r.SafeModeOk) -InformationAction Continue
                [pscustomobject]@{
                    Host=$t; Account=$r.Account; EnabledBefore=$r.EnabledBefore; EnabledAfter=$r.EnabledAfter;
                    PasswordSet=$r.PasswordSet; SafeModeOk=$r.SafeModeOk; Status='OK'
                }
            } catch {
                Write-Information "[FAIL] $t  $($_.Exception.Message)" -InformationAction Continue
                [pscustomobject]@{
                    Host=$t; Account=''; EnabledBefore=''; EnabledAfter=''; PasswordSet=$false; SafeModeOk='';
                    Status="ERROR: $($_.Exception.Message)"
                }
            }
        }
    }

    $bgVerifyBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { Show-Toast -Message 'No targets' -Kind Warning; return }
        $bgConsole.Text.ClearLog()
        $bgConsole.Text.AppendLog("# Verify built-in admin on $($targets.Count) host(s)")
        $bgGrid.ItemsSource = $null
        Set-ButtonBusy -Button $bgVerifyBtn -Busy $true
        Invoke-Async -Script $bgRemoteAction -Arguments @($targets, $null, $false, $false, $true) `
          -OnProgress { param($l) $bgConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $bgVerifyBtn -Busy $false
            $bgGrid.ItemsSource = $r
            $ok = @($r | Where-Object { $_.Status -eq 'OK' }).Count
            Write-AuditLog -Action 'BreakGlassVerify' -Target ($targets -join ',') -Details "$ok/$(@($r).Count) ok"
            $tkind = if ($ok -eq @($r).Count) { 'Success' } else { 'Warning' }
            Show-Toast -Message "Verify: $ok/$(@($r).Count) ok" -Kind $tkind
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $bgVerifyBtn -Busy $false
            Show-Toast -Message "Verify failed: $($e.Exception.Message)" -Kind Error
          }.GetNewClosure()
    }.GetNewClosure())

    $bgApplyBtn.Add_Click({
        $targets = & $getTargets
        if ($targets.Count -eq 0) { Show-Toast -Message 'No targets' -Kind Warning; return }

        $sec = Show-Prompt -Title 'Break-glass password' -Message 'Enter the new password for the built-in Administrator. Use a long passphrase that meets the strictest GPO complexity in your fleet.' -Password
        if (-not $sec) { return }
        # Local length check before dispatching (avoids per-host policy failures)
        $plainLen = ([Runtime.InteropServices.Marshal]::PtrToStringAuto(
                     [Runtime.InteropServices.Marshal]::SecureStringToBSTR($sec))).Length
        if ($plainLen -lt 14) {
            Show-Toast -Message "Password is $plainLen chars; require >= 14" -Kind Warning
            return
        }

        $disable  = [bool]$bgChkDisable.IsChecked
        $neverExp = [bool]$bgChkNeverExp.IsChecked
        $msg = "Rotate built-in Administrator password on $($targets.Count) host(s)?`n`n" +
               "Disable after: $disable`nPassword never expires: $neverExp`n`n" +
               "This is destructive and irreversible. Make sure the password is recorded in your offline vault BEFORE proceeding."
        if (-not (Show-Confirm -Title 'Confirm rotation' -Message $msg -Danger -ConfirmText 'Rotate')) { return }

        $bgConsole.Text.ClearLog()
        $bgConsole.Text.AppendLog("# Rotating built-in admin on $($targets.Count) host(s) (disable=$disable, neverExp=$neverExp)")
        $bgGrid.ItemsSource = $null
        Set-ButtonBusy -Button $bgApplyBtn -Busy $true -BusyText 'Rotating...'
        Invoke-Async -Script $bgRemoteAction -Arguments @($targets, $sec, $disable, $neverExp, $false) `
          -OnProgress { param($l) $bgConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $bgApplyBtn -Busy $false
            $bgGrid.ItemsSource = $r
            $ok = @($r | Where-Object { $_.Status -eq 'OK' }).Count
            # NOTE: never log the password itself
            $resultStr = if ($ok -eq @($r).Count) { 'OK' } else { 'PARTIAL' }
            Write-AuditLog -Action 'BreakGlassRotate' -Target ($targets -join ',') `
                           -Result $resultStr `
                           -Details "ok=$ok total=$(@($r).Count) disable=$disable neverExp=$neverExp"
            $tkind = if ($ok -eq @($r).Count) { 'Success' } else { 'Warning' }
            Show-Toast -Message "Rotation: $ok/$(@($r).Count) ok" -Kind $tkind
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $bgApplyBtn -Busy $false
            Show-Toast -Message "Rotation failed: $($e.Exception.Message)" -Kind Error
          }.GetNewClosure()
    }.GetNewClosure())

    # Wrap in scrollviewer in case of small windows
    $scroll = New-Object System.Windows.Controls.ScrollViewer
    $scroll.VerticalScrollBarVisibility = 'Auto'
    $scroll.Content = $wrap
    [void]$root.Children.Add($scroll)
    return $root
}
#endregion

#region --- Maintenance module ------------------------------------------------
function New-MaintenancePage {
    $root = New-Object System.Windows.Controls.DockPanel
    [System.Windows.Controls.DockPanel]::SetDock(($hdr = (New-PageHeader -Title 'Maintenance' `
        -Subtitle 'Disk cleanup, SFC/DISM, Windows Update status, pending reboot, common service resets.')), 'Top')
    [void]$root.Children.Add($hdr)

    $tabs = New-Object System.Windows.Controls.TabControl
    $tabs.Background = 'Transparent'; $tabs.BorderThickness = '0'

    # ----- Disk cleanup -----
    $tabClean = New-Object System.Windows.Controls.TabItem
    $tabClean.Header = 'Disk cleanup'
    $cleanStack = New-Object System.Windows.Controls.StackPanel; $cleanStack.Margin = '0,10,0,0'
    $cleanInfo = New-Object System.Windows.Controls.TextBlock
    $cleanInfo.TextWrapping = 'Wrap'
    $cleanInfo.Text = 'Removes temp files from %TEMP%, %SystemRoot%\Temp, and the Windows Update download cache. Choose what to clean.'
    $cleanInfo.Margin = '0,0,0,10'
    $cleanInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$cleanStack.Children.Add($cleanInfo)

    $cbUserTemp = New-Object System.Windows.Controls.CheckBox; $cbUserTemp.Content = 'User %TEMP%'; $cbUserTemp.IsChecked = $true; $cbUserTemp.Margin = '0,2'
    $cbSysTemp  = New-Object System.Windows.Controls.CheckBox; $cbSysTemp.Content  = 'System Temp'; $cbSysTemp.IsChecked  = $true; $cbSysTemp.Margin = '0,2'
    $cbWUCache  = New-Object System.Windows.Controls.CheckBox; $cbWUCache.Content  = 'Windows Update cache (SoftwareDistribution\Download)'; $cbWUCache.Margin = '0,2'
    $cbPrefetch = New-Object System.Windows.Controls.CheckBox; $cbPrefetch.Content = 'Prefetch'; $cbPrefetch.Margin = '0,2'
    $cbRecycle  = New-Object System.Windows.Controls.CheckBox; $cbRecycle.Content  = 'Recycle bin'; $cbRecycle.Margin = '0,2'
    foreach ($cb in @($cbUserTemp, $cbSysTemp, $cbWUCache, $cbPrefetch, $cbRecycle)) { [void]$cleanStack.Children.Add($cb) }

    $cleanBtn = New-Object System.Windows.Controls.Button
    $cleanBtn.Content = 'Run disk cleanup'; $cleanBtn.HorizontalAlignment = 'Left'; $cleanBtn.Margin = '0,10,0,10'
    $cleanBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$cleanStack.Children.Add($cleanBtn)
    $cleanConsole = New-OutputConsole -MinHeight 240
    [void]$cleanStack.Children.Add($cleanConsole.Border)

    $cleanBtn.Add_Click({
        $opts = [pscustomobject]@{
            UserTemp = [bool]$cbUserTemp.IsChecked
            SysTemp  = [bool]$cbSysTemp.IsChecked
            WUCache  = [bool]$cbWUCache.IsChecked
            Prefetch = [bool]$cbPrefetch.IsChecked
            Recycle  = [bool]$cbRecycle.IsChecked
        }
        if (-not (Show-Confirm -Message "Proceed with disk cleanup? This will delete temporary files.")) { return }
        $cleanConsole.Text.ClearLog()
        Set-ButtonBusy -Button $cleanBtn -Busy $true -BusyText 'Cleaning...'
        Invoke-Async -Script {
            param($opts)
            function Remove-InPath {
                param($path, $label)
                if (-not (Test-Path $path)) { Write-Information "[skip] $label not found"; return 0 }
                $sizeBefore = 0
                try {
                    $sizeBefore = (Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue |
                        Measure-Object -Property Length -Sum).Sum
                } catch {}
                $sizeBefore = if ($sizeBefore) { $sizeBefore } else { 0 }
                try {
                    Get-ChildItem $path -Force -ErrorAction SilentlyContinue | ForEach-Object {
                        try { Remove-Item $_.FullName -Recurse -Force -ErrorAction Stop } catch {}
                    }
                } catch {}
                $sizeAfter = 0
                try {
                    $sizeAfter = (Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue |
                        Measure-Object -Property Length -Sum).Sum
                } catch {}
                $sizeAfter = if ($sizeAfter) { $sizeAfter } else { 0 }
                $freed = [math]::Max(0, $sizeBefore - $sizeAfter)
                $mb = [math]::Round($freed/1MB, 1)
                Write-Information ("[done] {0}: freed {1} MB" -f $label, $mb) -InformationAction Continue
                return $freed
            }
            $total = 0
            if ($opts.UserTemp) { $total += Remove-InPath $env:TEMP 'User %TEMP%' }
            if ($opts.SysTemp) { $total += Remove-InPath "$env:SystemRoot\Temp" 'System Temp' }
            if ($opts.WUCache) {
                try {
                    Write-Information "[info] Stopping wuauserv..." -InformationAction Continue
                    Stop-Service wuauserv -Force -ErrorAction SilentlyContinue
                    $total += Remove-InPath "$env:SystemRoot\SoftwareDistribution\Download" 'WU cache'
                    Start-Service wuauserv -ErrorAction SilentlyContinue
                    Write-Information "[info] Restarted wuauserv" -InformationAction Continue
                } catch {
                    Write-Information "[warn] WU cleanup partial: $($_.Exception.Message)" -InformationAction Continue
                }
            }
            if ($opts.Prefetch) { $total += Remove-InPath "$env:SystemRoot\Prefetch" 'Prefetch' }
            if ($opts.Recycle) {
                try {
                    Write-Information "[info] Emptying Recycle Bin..." -InformationAction Continue
                    Clear-RecycleBin -Force -ErrorAction Stop
                    Write-Information "[done] Recycle Bin" -InformationAction Continue
                } catch {
                    Write-Information "[warn] Recycle Bin: $($_.Exception.Message)" -InformationAction Continue
                }
            }
            [pscustomobject]@{ TotalMB = [math]::Round($total/1MB, 1) }
        } -Arguments @($opts) `
          -OnProgress { param($l) $cleanConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $cleanBtn -Busy $false
            $cleanConsole.Text.AppendLog("")
            $cleanConsole.Text.AppendLog("# Total freed: $($r.TotalMB) MB")
            Show-Toast -Message "Freed $($r.TotalMB) MB" -Kind Success
            Write-AuditLog -Action 'DiskCleanup' -Details "$($r.TotalMB) MB"
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $cleanBtn -Busy $false
            $cleanConsole.Text.AppendLog("ERROR: $($e.Exception.Message)")
          }.GetNewClosure()
    }.GetNewClosure())
    $tabClean.Content = $cleanStack

    # ----- SFC / DISM -----
    $tabRepair = New-Object System.Windows.Controls.TabItem
    $tabRepair.Header = 'SFC / DISM'
    $repStack = New-Object System.Windows.Controls.StackPanel; $repStack.Margin = '0,10,0,0'
    $repInfo = New-Object System.Windows.Controls.TextBlock
    $repInfo.TextWrapping = 'Wrap'
    $repInfo.Text = 'System File Checker and DISM can repair Windows system files. These can take several minutes. Requires admin.'
    $repInfo.Margin = '0,0,0,10'
    $repInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$repStack.Children.Add($repInfo)
    $repRow = New-Object System.Windows.Controls.StackPanel; $repRow.Orientation = 'Horizontal'; $repRow.Margin = '0,0,0,10'
    $sfcBtn = New-Object System.Windows.Controls.Button; $sfcBtn.Content = 'Run SFC /scannow'; $sfcBtn.Margin = '0,0,6,0'
    $sfcBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $dismScan = New-Object System.Windows.Controls.Button; $dismScan.Content = 'DISM ScanHealth'; $dismScan.Margin = '0,0,6,0'
    $dismScan.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $dismRest = New-Object System.Windows.Controls.Button; $dismRest.Content = 'DISM RestoreHealth'
    $dismRest.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$repRow.Children.Add($sfcBtn); [void]$repRow.Children.Add($dismScan); [void]$repRow.Children.Add($dismRest)
    [void]$repStack.Children.Add($repRow)
    $repConsole = New-OutputConsole -MinHeight 300
    [void]$repStack.Children.Add($repConsole.Border)

    $runProc = {
        param($btn, $exe, $params, $label)
        if (-not (Show-Confirm -Message "Run $label? This may take several minutes.")) { return }
        $repConsole.Text.ClearLog()
        $repConsole.Text.AppendLog("# $label starting...")
        Set-ButtonBusy -Button $btn -Busy $true -BusyText 'Running...'
        Invoke-Async -Script {
            param($exe, $params)
            $psi = New-Object System.Diagnostics.ProcessStartInfo
            $psi.FileName = $exe
            $psi.Arguments = $params
            $psi.RedirectStandardOutput = $true
            $psi.RedirectStandardError = $true
            $psi.UseShellExecute = $false
            $psi.CreateNoWindow = $true
            $p = [System.Diagnostics.Process]::Start($psi)
            while (-not $p.StandardOutput.EndOfStream) {
                $line = $p.StandardOutput.ReadLine()
                if ($line) { Write-Information $line -InformationAction Continue }
            }
            $err = $p.StandardError.ReadToEnd()
            $p.WaitForExit()
            if ($err) { Write-Information "STDERR: $err" -InformationAction Continue }
            return $p.ExitCode
        } -Arguments @($exe, $params) `
          -OnProgress { param($l) $repConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            param($rc)
            Set-ButtonBusy -Button $btn -Busy $false
            $repConsole.Text.AppendLog("# Exit code: $rc")
            Write-AuditLog -Action $label -Result "ExitCode=$rc"
            $tkind = if ($rc -eq 0) { 'Success' } else { 'Warning' }
            Show-Toast -Message "$label exited $rc" -Kind $tkind
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $btn -Busy $false
            $repConsole.Text.AppendLog("ERROR: $($e.Exception.Message)")
          }.GetNewClosure()
    }
    $sfcBtn.Add_Click({ & $runProc $sfcBtn 'sfc.exe' '/scannow' 'SFC /scannow' }.GetNewClosure())
    $dismScan.Add_Click({ & $runProc $dismScan 'dism.exe' '/Online /Cleanup-Image /ScanHealth' 'DISM ScanHealth' }.GetNewClosure())
    $dismRest.Add_Click({ & $runProc $dismRest 'dism.exe' '/Online /Cleanup-Image /RestoreHealth' 'DISM RestoreHealth' }.GetNewClosure())
    $tabRepair.Content = $repStack

    # ----- Windows Update status -----
    $tabWU = New-Object System.Windows.Controls.TabItem
    $tabWU.Header = 'Windows Update'
    $wuStack = New-Object System.Windows.Controls.StackPanel; $wuStack.Margin = '0,10,0,0'
    $wuBtn = New-Object System.Windows.Controls.Button
    $wuBtn.Content = 'Check status'; $wuBtn.HorizontalAlignment = 'Left'; $wuBtn.Margin = '0,0,0,10'
    $wuBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$wuStack.Children.Add($wuBtn)
    $wuConsole = New-OutputConsole -MinHeight 300
    [void]$wuStack.Children.Add($wuConsole.Border)
    $wuBtn.Add_Click({
        $wuConsole.Text.ClearLog()
        Set-ButtonBusy -Button $wuBtn -Busy $true
        Invoke-Async -Script {
            $out = ''
            $out += "=== Service state ===`r`n"
            try {
                $s = Get-Service wuauserv -ErrorAction Stop
                $out += "wuauserv: $($s.Status) / $($s.StartType)`r`n"
            } catch { $out += "wuauserv: ERROR $_`r`n" }

            $out += "`r`n=== Pending reboot indicators ===`r`n"
            $checks = @(
                @{ Path='HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending'; Label='CBS RebootPending' },
                @{ Path='HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired'; Label='WU RebootRequired' }
            )
            foreach ($c in $checks) {
                $out += "- $($c.Label): $((Test-Path $c.Path))`r`n"
            }

            $out += "`r`n=== Last 10 installed updates ===`r`n"
            try {
                $out += (Get-HotFix | Sort-Object InstalledOn -Descending |
                    Select-Object -First 10 HotFixID, Description, InstalledOn | Format-Table -AutoSize | Out-String)
            } catch { $out += "Error: $_`r`n" }

            $out += "`r`n=== Available updates (via COM) ===`r`n"
            try {
                $session = New-Object -ComObject Microsoft.Update.Session
                $searcher = $session.CreateUpdateSearcher()
                $result = $searcher.Search("IsInstalled=0 and Type='Software' and IsHidden=0")
                if ($result.Updates.Count -eq 0) {
                    $out += "No pending updates found.`r`n"
                } else {
                    foreach ($u in $result.Updates) {
                        $out += "- $($u.Title)`r`n"
                    }
                }
            } catch {
                $out += "Could not enumerate available updates: $($_.Exception.Message)`r`n"
                $out += "(This check may require admin and the Windows Update COM API.)`r`n"
            }
            $out
        } -OnComplete {
            param($r)
            Set-ButtonBusy -Button $wuBtn -Busy $false
            $wuConsole.Text.AppendLog($r)
            Write-AuditLog -Action 'WUStatusCheck'
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $wuBtn -Busy $false
            $wuConsole.Text.AppendLog("ERROR: $($e.Exception.Message)")
        }.GetNewClosure()
    }.GetNewClosure())
    $tabWU.Content = $wuStack

    # ----- Service resets -----
    $tabSvc = New-Object System.Windows.Controls.TabItem
    $tabSvc.Header = 'Service resets'
    $srStack = New-Object System.Windows.Controls.StackPanel; $srStack.Margin = '0,10,0,0'
    $srInfo = New-Object System.Windows.Controls.TextBlock
    $srInfo.TextWrapping = 'Wrap'
    $srInfo.Text = 'Quick actions to reset commonly-stuck Windows services. Each is a restart of the related service(s).'
    $srInfo.Margin = '0,0,0,10'
    $srInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$srStack.Children.Add($srInfo)

    $actions = @(
        @{ Label='Restart print spooler'; Svcs=@('Spooler') }
        @{ Label='Flush & restart DNS client'; Svcs=@('Dnscache'); PreCmd='ipconfig /flushdns' }
        @{ Label='Restart Windows Update services'; Svcs=@('wuauserv','bits','cryptsvc') }
        @{ Label='Restart Workstation / Server'; Svcs=@('LanmanWorkstation','LanmanServer') }
        @{ Label='Restart Windows Time'; Svcs=@('W32Time') }
    )
    $srWrap = New-Object System.Windows.Controls.WrapPanel
    foreach ($a in $actions) {
        $b = New-Object System.Windows.Controls.Button
        $b.Content = $a['Label']; $b.Margin = '0,0,6,6'
        $b.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
        $svcs = $a['Svcs']; $pre = $a['PreCmd']; $label = $a['Label']
        $b.Add_Click({
            if (-not (Show-Confirm -Message "Run '$label'?")) { return }
            Invoke-Async -Script {
                param($svcs, $pre)
                if ($pre) { cmd /c $pre | Out-Null }
                foreach ($s in $svcs) {
                    try { Restart-Service -Name $s -Force -ErrorAction Stop } catch {}
                }
                "ok"
            } -Arguments @($svcs, $pre) -OnComplete {
                Show-Toast -Message "$label complete" -Kind Success
                Write-AuditLog -Action 'ServiceReset' -Target $label
            }.GetNewClosure() -OnError {
                param($e) Show-Toast -Message "Failed: $($e.Exception.Message)" -Kind Error
            }.GetNewClosure()
        }.GetNewClosure())
        [void]$srWrap.Children.Add($b)
    }
    [void]$srStack.Children.Add($srWrap)
    $tabSvc.Content = $srStack

    [void]$tabs.Items.Add($tabClean)
    [void]$tabs.Items.Add($tabRepair)
    [void]$tabs.Items.Add($tabWU)
    [void]$tabs.Items.Add($tabSvc)
    [void]$root.Children.Add($tabs)
    return $root
}
#endregion

#region --- History module ----------------------------------------------------
function New-HistoryPage {
    $root = New-Object System.Windows.Controls.DockPanel
    [System.Windows.Controls.DockPanel]::SetDock(($hdr = (New-PageHeader -Title 'History' `
        -Subtitle "Every action this tool performs. Log file: $($script:LogFile)")), 'Top')
    [void]$root.Children.Add($hdr)

    $ctrls = New-Object System.Windows.Controls.StackPanel
    $ctrls.Orientation = 'Horizontal'; $ctrls.Margin = '0,0,0,10'
    [System.Windows.Controls.DockPanel]::SetDock($ctrls, 'Top')
    $filter = New-Object System.Windows.Controls.TextBox
    $filter.Width = 260; $filter.Margin = '0,0,8,0'
    $filter.ToolTip = 'Filter (action or target)'
    $exportBtn = New-Object System.Windows.Controls.Button
    $exportBtn.Content = 'Export CSV'; $exportBtn.Margin = '0,0,6,0'
    $exportBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $openLogBtn = New-Object System.Windows.Controls.Button
    $openLogBtn.Content = 'Open log folder'; $openLogBtn.Margin = '0,0,6,0'
    $openLogBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$ctrls.Children.Add($filter); [void]$ctrls.Children.Add($exportBtn); [void]$ctrls.Children.Add($openLogBtn)
    [void]$root.Children.Add($ctrls)

    $grid = New-Object System.Windows.Controls.DataGrid
    foreach ($c in @(
        @{H='Time';    B='time';    W='160'},
        @{H='Action';  B='action';  W='180'},
        @{H='Target';  B='target';  W='220'},
        @{H='Result';  B='result';  W='80'},
        @{H='User';    B='user';    W='180'},
        @{H='Details'; B='details'; W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$grid.Columns.Add($col)
    }

    $view = [System.Windows.Data.CollectionViewSource]::GetDefaultView($script:HistoryItems)
    $grid.ItemsSource = $view
    $filter.Add_TextChanged({
        $q = $filter.Text
        if (-not $q) { $view.Filter = $null }
        else {
            $view.Filter = [Predicate[object]]{
                param($item)
                ($item.action -and $item.action -like "*$q*") -or
                ($item.target -and $item.target -like "*$q*")
            }.GetNewClosure()
        }
    }.GetNewClosure())
    $exportBtn.Add_Click({
        $dlg = New-Object Microsoft.Win32.SaveFileDialog
        $dlg.Filter = 'CSV (*.csv)|*.csv'
        $dlg.FileName = "sysadmintoolkit-history-$(Get-Date -Format yyyyMMdd-HHmmss).csv"
        if ($dlg.ShowDialog()) {
            @($script:HistoryItems) | Export-Csv -Path $dlg.FileName -NoTypeInformation -Encoding UTF8
            Show-Toast -Message "Exported $(@($script:HistoryItems).Count) rows" -Kind Success
        }
    }.GetNewClosure())
    $openLogBtn.Add_Click({
        try { Start-Process explorer.exe $script:DataDir } catch {}
    }.GetNewClosure())
    [void]$root.Children.Add($grid)
    return $root
}
#endregion

