        Set-ButtonBusy -Button $checkBtn -Busy $true
        Invoke-Async -Script {
            param($targets)
            $results = foreach ($t in $targets) {
                try {
                    $r = Test-WSMan -ComputerName $t -ErrorAction Stop
                    Write-Information "[OK]   $t  (protocol $($r.ProductVendor))" -InformationAction Continue
                    [pscustomobject]@{ Host=$t; OK=$true }
                } catch {
                    Write-Information "[FAIL] $t  $($_.Exception.Message)" -InformationAction Continue
                    [pscustomobject]@{ Host=$t; OK=$false }
                }
            }
            $results
        } -Arguments @(,$targets) `
          -OnProgress { param($l) $cmdConsole.Text.AppendLog($l) }.GetNewClosure() `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $checkBtn -Busy $false
            $ok = @($r | Where-Object OK).Count
            $tkind = if ($ok -eq @($r).Count) { 'Success' } else { 'Warning' }
            Show-Toast -Message "WinRM: $ok of $(@($r).Count) reachable" -Kind $tkind
          }.GetNewClosure()
    }.GetNewClosure())

    $cmdRun.Add_Click({
        $targets = & $getTargets
