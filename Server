    $evBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')

    $evExportBtn = New-Object System.Windows.Controls.Button
    $evExportBtn.Content = 'Export CSV'; $evExportBtn.Margin = '8,0,0,0'
    $evExportBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $evExportBtn.IsEnabled = $false

    [void]$evCtrls.Children.Add($evLogCombo)
    [void]$evCtrls.Children.Add($evLevelCombo)
    [void]$evCtrls.Children.Add($evHoursCombo)
    [void]$evCtrls.Children.Add($evHost)
    [void]$evCtrls.Children.Add($evBtn)
    [void]$evCtrls.Children.Add($evExportBtn)
    [void]$evGrid.Children.Add($evCtrls)

    $evData = New-Object System.Windows.Controls.DataGrid
    [System.Windows.Controls.Grid]::SetRow($evData, 1)
    foreach ($c in @(
        @{H='Time';   B='TimeCreated';  W='140'},
        @{H='Level';  B='LevelDisplayName'; W='90'},
        @{H='ID';     B='Id';           W='70'},
        @{H='Source'; B='ProviderName'; W='200'},
        @{H='Message';B='Message';      W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$evData.Columns.Add($col)
    }
    [void]$evGrid.Children.Add($evData)

    $evBtn.Add_Click({
        $logName = $evLogCombo.SelectedItem
        $level   = $evLevelCombo.SelectedItem
        $hoursMap = @{ '1 hour'=1; '6 hours'=6; '24 hours'=24; '7 days'=24*7; '30 days'=24*30 }
        $hours   = $hoursMap[$evHoursCombo.SelectedItem]
        $remote  = if ($evHost.Text.Trim()) { $evHost.Text.Trim() } else { $null }
        Set-ButtonBusy -Button $evBtn -Busy $true -BusyText 'Fetching...'
        $evData.ItemsSource = $null

        Invoke-Async -Script {
            param($logName, $level, $hours, $remote)
            $filter = @{ LogName = $logName; StartTime = (Get-Date).AddHours(-$hours) }
            $levelMap = @{ Critical=1; Error=2; Warning=3; Information=4 }
            if ($level -ne 'All') { $filter.Level = $levelMap[$level] }
            $params = @{ FilterHashtable = $filter; MaxEvents = 500; ErrorAction='Stop' }
            if ($remote) { $params.ComputerName = $remote }
            Get-WinEvent @params | Select-Object TimeCreated, LevelDisplayName, Id, ProviderName,
                @{N='Message';E={ if ($_.Message) { ($_.Message -replace '\s+',' ').Substring(0, [math]::Min(300, $_.Message.Length)) } else { '' } }}
        } -Arguments @($logName, $level, $hours, $remote) `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $evBtn -Busy $false
            $evData.ItemsSource = $r
            $evExportBtn.IsEnabled = ($r -and $r.Count -gt 0)
