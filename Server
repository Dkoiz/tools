#region --- Theme management --------------------------------------------------
function Set-AppTheme {
    param(
        [ValidateSet('Light', 'Dark')] [string] $Theme,
        [string] $Accent = $script:Accent
    )

    $palettes = @{
        Light = @{
            Bg        = '#FFFFFF'
            BgAlt     = '#F5F5F5'
            CardBg    = '#FBFBFB'
            EdgeBrush = '#E1E1E1'
            TextBrush = '#1F1F1F'
            TextDim   = '#5E5E5E'
            NavHover  = '#EBEBEB'
            NavActive = '#E0EAF5'
            Console   = '#1A1A1A'
            ConsoleText = '#E6E6E6'
            Danger    = '#D13438'
            DangerHover = '#A82A2D'
            Success   = '#107C10'
            Warning   = '#CA8217'
        }
        Dark = @{
            Bg        = '#1E1E1E'
            BgAlt     = '#252526'
            CardBg    = '#2A2A2B'
            EdgeBrush = '#3A3A3B'
            TextBrush = '#F1F1F1'
            TextDim   = '#A0A0A0'
            NavHover  = '#2F2F30'
            NavActive = '#2A3A4F'
            Console   = '#0F0F10'
            ConsoleText = '#E6E6E6'
            Danger    = '#E05C60'
            DangerHover = '#C04448'
            Success   = '#3FA13F'
            Warning   = '#E2A445'
        }
    }

    $p = $palettes[$Theme]
    $win = $script:Window

    # Build a fresh ResourceDictionary with all theme brushes.
    $rd = New-Object System.Windows.ResourceDictionary

    foreach ($k in @($p.Keys)) {
        $hex = [string]$p[$k]
        $h = $hex.TrimStart('#')
        if ($h.Length -eq 6) {
            $aVal = 255
            $rVal = [Convert]::ToInt32($h.Substring(0,2), 16)
            $gVal = [Convert]::ToInt32($h.Substring(2,2), 16)
            $bVal = [Convert]::ToInt32($h.Substring(4,2), 16)
        } elseif ($h.Length -eq 8) {
            $aVal = [Convert]::ToInt32($h.Substring(0,2), 16)
            $rVal = [Convert]::ToInt32($h.Substring(2,2), 16)
            $gVal = [Convert]::ToInt32($h.Substring(4,2), 16)
            $bVal = [Convert]::ToInt32($h.Substring(6,2), 16)
        } else {
            throw "Invalid color for key '$k': $hex"
        }
        $color = [System.Windows.Media.Color]::FromArgb([byte]$aVal, [byte]$rVal, [byte]$gVal, [byte]$bVal)
        $brush = New-Object -TypeName System.Windows.Media.SolidColorBrush -ArgumentList $color
        $rd.Add([string]$k, $brush)
    }

    # Accent + AccentHover
    $ah = ([string]$Accent).TrimStart('#')
    $ar = [Convert]::ToInt32($ah.Substring(0,2), 16)
    $ag = [Convert]::ToInt32($ah.Substring(2,2), 16)
    $ab = [Convert]::ToInt32($ah.Substring(4,2), 16)
    $accentColor = [System.Windows.Media.Color]::FromArgb([byte]255, [byte]$ar, [byte]$ag, [byte]$ab)
    $accentBrush = New-Object -TypeName System.Windows.Media.SolidColorBrush -ArgumentList $accentColor
    $hoverColor = [System.Windows.Media.Color]::FromArgb(
        [byte]255,
        [byte][math]::Max(0, $ar - 20),
        [byte][math]::Max(0, $ag - 20),
        [byte][math]::Max(0, $ab - 20))
    $hoverBrush = New-Object -TypeName System.Windows.Media.SolidColorBrush -ArgumentList $hoverColor
    $rd.Add('Accent', $accentBrush)
    $rd.Add('AccentHover', $hoverBrush)

    # Sentinel to mark our dictionary so we can find and replace it on re-apply.
    $rd.Add('__SATTheme__', $true)

    # Remove any previously-installed theme dictionary, then merge in the new one.
    $existing = @()
    foreach ($md in $win.Resources.MergedDictionaries) {
        if ($md.Contains('__SATTheme__')) { $existing += $md }
    }
    foreach ($md in $existing) { [void]$win.Resources.MergedDictionaries.Remove($md) }
    [void]$win.Resources.MergedDictionaries.Add($rd)

    $script:Theme = $Theme

    $icon = $win.FindName('ThemeIcon')
    if ($icon) {
        $icon.Text = if ($Theme -eq 'Dark') { [char]0xE706 } else { [char]0xE708 }
    }
}
#endregion

#region --- Audit log ---------------------------------------------------------
$script:HistoryItems = New-Object System.Collections.ObjectModel.ObservableCollection[object]

function Write-AuditLog {
    param(
        [Parameter(Mandatory)] [string] $Action,
        [string] $Target = '',
        [string] $Result = 'OK',
        [string] $Details = ''
    )
    $entry = [ordered]@{
        time    = (Get-Date).ToString('o')
        user    = "$env:USERDOMAIN\$env:USERNAME"
        host    = $env:COMPUTERNAME
        action  = $Action
        target  = $Target
        result  = $Result
        details = $Details
    }
    try {
        ($entry | ConvertTo-Json -Compress) | Add-Content -Path $script:LogFile -Encoding UTF8
    } catch {}
    $obj = [pscustomobject]$entry
    $script:Window.Dispatcher.Invoke([action]{
        $script:HistoryItems.Insert(0, $obj)
        if ($script:HistoryItems.Count -gt $script:Config.HistoryInMemoryMax) {
            $script:HistoryItems.RemoveAt($script:HistoryItems.Count - 1)
        }
    })
}
#endregion

#region --- Async dispatcher --------------------------------------------------
$script:RunspacePool = [runspacefactory]::CreateRunspacePool(1, 8)
$script:RunspacePool.ApartmentState = 'STA'
$script:RunspacePool.Open()

function Invoke-Async {
    param(
        [Parameter(Mandatory)] [scriptblock] $Script,
        [object[]] $Arguments = @(),
        [scriptblock] $OnComplete,
        [scriptblock] $OnError,
        [scriptblock] $OnProgress    # called with (line) for streaming output
    )
    $ps = [powershell]::Create()
    $ps.RunspacePool = $script:RunspacePool
    [void]$ps.AddScript($Script)
    foreach ($a in $Arguments) { [void]$ps.AddArgument($a) }

    $state = [pscustomobject]@{
        PS       = $ps
        OnDone   = $OnComplete
        OnErr    = $OnError
        OnProg   = $OnProgress
        Handle   = $null
        LastInfo = 0
    }
    $state.Handle = $ps.BeginInvoke()

    $timer = New-Object System.Windows.Threading.DispatcherTimer
    $timer.Interval = [TimeSpan]::FromMilliseconds(80)
    $timer.Add_Tick({
        # Drain information stream for progress
        if ($state.OnProg -and $state.PS.Streams.Information.Count -gt $state.LastInfo) {
            for ($i = $state.LastInfo; $i -lt $state.PS.Streams.Information.Count; $i++) {
                try { & $state.OnProg $state.PS.Streams.Information[$i].MessageData }
                catch { Write-AuditLog -Action 'OnProgressError' -Result 'FAIL' -Details "$($_.Exception.Message) @ $($_.ScriptStackTrace -replace "`n",' | ')" }
            }
            $state.LastInfo = $state.PS.Streams.Information.Count
        }
        if ($state.Handle.IsCompleted) {
            $timer.Stop()
            try {
                $result = $state.PS.EndInvoke($state.Handle)
                # Drain any remaining info
                if ($state.OnProg -and $state.PS.Streams.Information.Count -gt $state.LastInfo) {
                    for ($i = $state.LastInfo; $i -lt $state.PS.Streams.Information.Count; $i++) {
                        try { & $state.OnProg $state.PS.Streams.Information[$i].MessageData }
                        catch { Write-AuditLog -Action 'OnProgressError' -Result 'FAIL' -Details "$($_.Exception.Message) @ $($_.ScriptStackTrace -replace "`n",' | ')" }
                    }
                }
                if ($state.PS.HadErrors -and $state.OnErr) {
                    $err = ($state.PS.Streams.Error | Select-Object -First 1)
                    try { & $state.OnErr $err }
                    catch { Write-AuditLog -Action 'OnErrorError' -Result 'FAIL' -Details "$($_.Exception.Message) @ $($_.ScriptStackTrace -replace "`n",' | ')" }
                } elseif ($state.OnDone) {
                    try { & $state.OnDone $result }
                    catch { Write-AuditLog -Action 'OnCompleteError' -Result 'FAIL' -Details "$($_.Exception.Message) @ $($_.ScriptStackTrace -replace "`n",' | ')" }
                }
            } catch {
                Write-AuditLog -Action 'AsyncTickError' -Result 'FAIL' -Details "$($_.Exception.Message) @ $($_.ScriptStackTrace -replace "`n",' | ')"
                if ($state.OnErr) { try { & $state.OnErr $_ } catch {} }
            } finally {
                $state.PS.Dispose()
            }
        }
    }.GetNewClosure())
    $timer.Start()
}
#endregion

#region --- Toast notifications -----------------------------------------------
function Show-Toast {
    param(
        [Parameter(Mandatory)] [string] $Message,
        [ValidateSet('Info', 'Success', 'Warning', 'Error')] [string] $Kind = 'Info',
        [int] $DurationMs = 3500
    )

    $iconMap = @{
        Info    = [char]0xE946   # info
        Success = [char]0xE930   # check
        Warning = [char]0xE7BA   # warning
        Error   = [char]0xEA39   # error
    }
    $brushKey = @{
        Info    = 'Accent'
        Success = 'Success'
        Warning = 'Warning'
        Error   = 'Danger'
    }[$Kind]

    $border = New-Object System.Windows.Controls.Border
    $border.SetResourceReference([System.Windows.Controls.Border]::StyleProperty, 'Card')
    $border.Margin     = '0,0,0,8'
    $border.MaxWidth   = 360
    $border.MinWidth   = 280
    $border.Effect     = New-Object System.Windows.Media.Effects.DropShadowEffect -Property @{
        BlurRadius = 16; ShadowDepth = 2; Opacity = 0.25
    }

    $g = New-Object System.Windows.Controls.Grid
    $cd0 = New-Object System.Windows.Controls.ColumnDefinition; $cd0.Width = 'Auto'
    $cd1 = New-Object System.Windows.Controls.ColumnDefinition
    [void]$g.ColumnDefinitions.Add($cd0); [void]$g.ColumnDefinitions.Add($cd1)

    $icon = New-Object System.Windows.Controls.TextBlock
    $icon.Text = $iconMap[$Kind]
    $icon.FontFamily = New-Object System.Windows.Media.FontFamily('Segoe Fluent Icons, Segoe MDL2 Assets')
    $icon.FontSize = 18; $icon.Margin = '0,0,10,0'; $icon.VerticalAlignment = 'Top'
    $icon.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, $brushKey)
    [System.Windows.Controls.Grid]::SetColumn($icon, 0)
    [void]$g.Children.Add($icon)

    $tb = New-Object System.Windows.Controls.TextBlock
    $tb.Text = $Message; $tb.TextWrapping = 'Wrap'
    $tb.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [System.Windows.Controls.Grid]::SetColumn($tb, 1)
    [void]$g.Children.Add($tb)

    $border.Child = $g
    [void]$script:ToastHost.Items.Add($border)

    $t = New-Object System.Windows.Threading.DispatcherTimer
    $t.Interval = [TimeSpan]::FromMilliseconds($DurationMs)
    $t.Add_Tick({
        $t.Stop()
        try { [void]$script:ToastHost.Items.Remove($border) } catch {}
    }.GetNewClosure())
    $t.Start()
}
#endregion

#region --- Confirm dialog ----------------------------------------------------
function Show-Confirm {
    param(
        [Parameter(Mandatory)] [string] $Message,
        [string] $Title = 'Confirm',
        [string] $ConfirmText = 'Yes',
        [string] $CancelText = 'Cancel',
        [switch] $Danger
    )

    if (-not $script:Config.ConfirmDestructive -and -not $Danger) { return $true }

    $w = New-Object System.Windows.Window
    $w.Title = $Title
    $w.Width = 440; $w.Height = 200
    $w.WindowStartupLocation = 'CenterOwner'
    $w.Owner = $script:Window
    $w.ResizeMode = 'NoResize'
    $w.WindowStyle = 'ToolWindow'
    $w.FontFamily = 'Segoe UI'
    $w.SetResourceReference([System.Windows.Controls.Control]::BackgroundProperty, 'Bg')

    $root = New-Object System.Windows.Controls.Grid
    $root.Margin = '20'
    $rd0 = New-Object System.Windows.Controls.RowDefinition
    $rd1 = New-Object System.Windows.Controls.RowDefinition; $rd1.Height = 'Auto'
    [void]$root.RowDefinitions.Add($rd0); [void]$root.RowDefinitions.Add($rd1)

    $msg = New-Object System.Windows.Controls.TextBlock
    $msg.Text = $Message; $msg.TextWrapping = 'Wrap'; $msg.FontSize = 14
    $msg.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [System.Windows.Controls.Grid]::SetRow($msg, 0)
    [void]$root.Children.Add($msg)

    $panel = New-Object System.Windows.Controls.StackPanel
    $panel.Orientation = 'Horizontal'; $panel.HorizontalAlignment = 'Right'
    $panel.Margin = '0,16,0,0'
    [System.Windows.Controls.Grid]::SetRow($panel, 1)

    $cancel = New-Object System.Windows.Controls.Button
    $cancel.Content = $CancelText; $cancel.Margin = '0,0,8,0'; $cancel.MinWidth = 80
    $cancel.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $cancel.Add_Click({ $w.Tag = $false; $w.Close() }.GetNewClosure())

    $ok = New-Object System.Windows.Controls.Button
    $ok.Content = $ConfirmText; $ok.MinWidth = 80
    $styleKey = if ($Danger) { 'DangerBtn' } else { 'AccentBtn' }
    $ok.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, $styleKey)
    $ok.Add_Click({ $w.Tag = $true; $w.Close() }.GetNewClosure())

    [void]$panel.Children.Add($cancel)
    [void]$panel.Children.Add($ok)
    [void]$root.Children.Add($panel)
    $w.Content = $root

    $w.Tag = $false
    [void]$w.ShowDialog()
    return [bool]$w.Tag
}

# Prompt for a single string
function Show-Prompt {
    param(
        [Parameter(Mandatory)] [string] $Message,
        [string] $Title = 'Input',
        [string] $Default = '',
        [switch] $Password
    )
    $w = New-Object System.Windows.Window
    $w.Title = $Title; $w.Width = 440; $w.Height = 210
    $w.WindowStartupLocation = 'CenterOwner'; $w.Owner = $script:Window
    $w.ResizeMode = 'NoResize'; $w.WindowStyle = 'ToolWindow'
    $w.FontFamily = 'Segoe UI'
    $w.SetResourceReference([System.Windows.Controls.Control]::BackgroundProperty, 'Bg')

    $root = New-Object System.Windows.Controls.Grid; $root.Margin = '20'
    $r0 = New-Object System.Windows.Controls.RowDefinition; $r0.Height = 'Auto'
    $r1 = New-Object System.Windows.Controls.RowDefinition; $r1.Height = 'Auto'
    $r2 = New-Object System.Windows.Controls.RowDefinition; $r2.Height = 'Auto'
    [void]$root.RowDefinitions.Add($r0); [void]$root.RowDefinitions.Add($r1); [void]$root.RowDefinitions.Add($r2)

    $msg = New-Object System.Windows.Controls.TextBlock
    $msg.Text = $Message; $msg.TextWrapping = 'Wrap'; $msg.Margin = '0,0,0,10'
    $msg.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [System.Windows.Controls.Grid]::SetRow($msg, 0)
    [void]$root.Children.Add($msg)

    if ($Password) {
        $input = New-Object System.Windows.Controls.PasswordBox
    } else {
        $input = New-Object System.Windows.Controls.TextBox
        $input.Text = $Default
    }
    [System.Windows.Controls.Grid]::SetRow($input, 1)
    [void]$root.Children.Add($input)

    $panel = New-Object System.Windows.Controls.StackPanel
    $panel.Orientation = 'Horizontal'; $panel.HorizontalAlignment = 'Right'
    $panel.Margin = '0,16,0,0'
    [System.Windows.Controls.Grid]::SetRow($panel, 2)

    $cancel = New-Object System.Windows.Controls.Button
    $cancel.Content = 'Cancel'; $cancel.Margin = '0,0,8,0'; $cancel.MinWidth = 80
    $cancel.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $cancel.Add_Click({ $w.Tag = $null; $w.Close() }.GetNewClosure())

    $ok = New-Object System.Windows.Controls.Button
    $ok.Content = 'OK'; $ok.MinWidth = 80
    $ok.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $ok.IsDefault = $true
    $ok.Add_Click({
        $w.Tag = if ($Password) { $input.SecurePassword } else { $input.Text }
        $w.Close()
    }.GetNewClosure())

    [void]$panel.Children.Add($cancel); [void]$panel.Children.Add($ok)
    [void]$root.Children.Add($panel)
    $w.Content = $root

    $w.Add_Loaded({ $input.Focus() | Out-Null }.GetNewClosure())
    [void]$w.ShowDialog()
    return $w.Tag
}
#endregion

