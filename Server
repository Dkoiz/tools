    $bgChkNeverExp = New-Object System.Windows.Controls.CheckBox
    $bgChkNeverExp.Content = 'Password never expires'; $bgChkNeverExp.IsChecked = $true
    $bgChkNeverExp.SetResourceReference([System.Windows.Controls.CheckBox]::ForegroundProperty, 'TextBrush')
    [void]$bgOpts.Children.Add($bgChkDisable); [void]$bgOpts.Children.Add($bgChkNeverExp)
