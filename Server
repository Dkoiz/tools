    $evLevelCombo.SelectedIndex = 2   # Error by default

    $evHoursCombo = New-Object System.Windows.Controls.ComboBox
    $evHoursCombo.Width = 120; $evHoursCombo.Margin = '0,0,8,0'
    @('1 hour', '6 hours', '24 hours', '7 days', '30 days') | ForEach-Object { [void]$evHoursCombo.Items.Add($_) }
