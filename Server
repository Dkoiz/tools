    $safeH = New-Object System.Windows.Controls.TextBlock
    $safeH.Text = 'Safety and performance'; $safeH.FontSize = 14; $safeH.FontWeight = 'SemiBold'; $safeH.Margin = '0,0,0,8'
    $safeH.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
