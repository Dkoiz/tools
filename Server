    $dnsType = New-Object System.Windows.Controls.ComboBox
    $dnsType.Width = 100; $dnsType.Margin = '0,0,8,0'
    @('A','AAAA','CNAME','MX','TXT','SRV','PTR','NS','SOA','ALL') | ForEach-Object { [void]$dnsType.Items.Add($_) }
    $dnsType.SelectedIndex = 0
    $dnsBtn = New-Object System.Windows.Controls.Button
    $dnsBtn.Content = 'Lookup'
    $dnsBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $dnsFlushBtn = New-Object System.Windows.Controls.Button
    $dnsFlushBtn.Content = 'Flush DNS cache'; $dnsFlushBtn.Margin = '8,0,0,0'
    $dnsFlushBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$dnsRow.Children.Add($dnsTxt); [void]$dnsRow.Children.Add($dnsType); [void]$dnsRow.Children.Add($dnsBtn); [void]$dnsRow.Children.Add($dnsFlushBtn)
    [void]$dnsStack.Children.Add($dnsRow)
    $dnsOut = New-OutputConsole -MinHeight 300
    [void]$dnsStack.Children.Add($dnsOut.Border)

    $dnsBtn.Add_Click({
        $q = $dnsTxt.Text.Trim(); $t = $dnsType.SelectedItem
        if (-not $q) { return }
        $dnsOut.Text.ClearLog()
        $dnsOut.Text.AppendLog("> Resolve-DnsName $q -Type $t`r`n")
        Invoke-Async -Script {
            param($q, $t)
            if ($t -eq 'ALL') {
                Resolve-DnsName $q -ErrorAction Stop | Out-String
            } else {
                Resolve-DnsName $q -Type $t -ErrorAction Stop | Out-String
            }
        } -Arguments @($q, $t) -OnComplete {
            param($r) $dnsOut.Text.AppendLog("$r")
        }.GetNewClosure() -OnError {
            param($e) $dnsOut.Text.AppendLog("ERROR: $($e.Exception.Message)")
        }.GetNewClosure()
    }.GetNewClosure())
    $dnsFlushBtn.Add_Click({
        Invoke-Async -Script { Clear-DnsClientCache; 'DNS cache cleared.' } -OnComplete {
            param($r) Show-Toast -Message $r -Kind Success; Write-AuditLog -Action 'FlushDNS'
        }.GetNewClosure() -OnError { param($e) Show-Toast -Message "Failed: $($e.Exception.Message)" -Kind Error }.GetNewClosure()
    }.GetNewClosure())
    $tabDns.Content = $dnsStack

    # ----- Trace route -----
    $tabTrace = New-Object System.Windows.Controls.TabItem
    $tabTrace.Header = 'Trace route'
    $traceStack = New-Object System.Windows.Controls.StackPanel
    $traceStack.Margin = '0,10,0,0'
    $traceRow = New-Object System.Windows.Controls.StackPanel; $traceRow.Orientation = 'Horizontal'; $traceRow.Margin = '0,0,0,10'
    $traceIn = New-Object System.Windows.Controls.TextBox; $traceIn.Width = 240; $traceIn.Margin = '0,0,8,0'
    $traceBtn = New-Object System.Windows.Controls.Button
    $traceBtn.Content = 'Trace'
    $traceBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$traceRow.Children.Add($traceIn); [void]$traceRow.Children.Add($traceBtn)
    [void]$traceStack.Children.Add($traceRow)
    $traceOut = New-OutputConsole -MinHeight 300
    [void]$traceStack.Children.Add($traceOut.Border)

    $traceBtn.Add_Click({
        $t = $traceIn.Text.Trim()
        if (-not $t) { return }
        $traceOut.Text.ClearLog()
        $traceOut.Text.AppendLog("> Test-NetConnection $t -TraceRoute`r`n")
        Set-ButtonBusy -Button $traceBtn -Busy $true -BusyText 'Tracing...'
        Invoke-Async -Script {
            param($t)
            Test-NetConnection -ComputerName $t -TraceRoute -ErrorAction Stop | Out-String
        } -Arguments @($t) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $traceBtn -Busy $false
            $traceOut.Text.AppendLog("$r")
            Write-AuditLog -Action 'TraceRoute' -Target $t
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $traceBtn -Busy $false
            $traceOut.Text.AppendLog("ERROR: $($e.Exception.Message)")
        }.GetNewClosure()
    }.GetNewClosure())
    $tabTrace.Content = $traceStack

    # ----- IP config -----
    $tabIp = New-Object System.Windows.Controls.TabItem
    $tabIp.Header = 'IP config'
    $ipStack = New-Object System.Windows.Controls.StackPanel
    $ipStack.Margin = '0,10,0,0'
    $ipBtn = New-Object System.Windows.Controls.Button
    $ipBtn.Content = 'Refresh'; $ipBtn.HorizontalAlignment = 'Left'; $ipBtn.Margin = '0,0,0,10'
    $ipBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$ipStack.Children.Add($ipBtn)
    $ipOut = New-OutputConsole -MinHeight 340
    [void]$ipStack.Children.Add($ipOut.Border)
    $ipBtn.Add_Click({
        $ipOut.Text.ClearLog()
        Invoke-Async -Script {
            $out = ''
            $out += "=== IP Configuration ===`r`n"
            $out += (ipconfig /all | Out-String)
            $out
        } -OnComplete { param($r) $ipOut.Text.AppendLog($r) }.GetNewClosure()
    }.GetNewClosure())
    $tabIp.Content = $ipStack

    [void]$tabs.Items.Add($tabSweep)
    [void]$tabs.Items.Add($tabPort)
    [void]$tabs.Items.Add($tabDns)
    [void]$tabs.Items.Add($tabTrace)
    [void]$tabs.Items.Add($tabIp)
    [void]$root.Children.Add($tabs)
    return $root
}
