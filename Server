function Show-Page {
    param([string] $Key)
    $p = $script:Pages[$Key]
    if (-not $p) { return }
    if (-not $p.Cache) {
        try {
            $p.Cache = & $p.Factory
        } catch {
            $err = New-Object System.Windows.Controls.TextBlock
            $err.Text = "Error loading page: $($_.Exception.Message)"
            $err.TextWrapping = 'Wrap'; $err.Foreground = 'Red'
            $p.Cache = $err
            Write-AuditLog -Action 'PageLoadError' -Target $Key -Result 'FAIL' -Details $_.Exception.Message
        }
    }
    $ContentHost.Content = $p.Cache
    if ($p.Nav -and -not $p.Nav.IsChecked) { $p.Nav.IsChecked = $true }
    $StatusText.Text = $p.Title
}

foreach ($key in $script:Pages.Keys) {
    $k = $key
    $script:Pages[$k].Nav.Add_Checked({ Show-Page -Key $k }.GetNewClosure())
