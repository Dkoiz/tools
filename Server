    @{ Key='Maintenance'; Title='Windows Update';    Sub='WU status and pending updates' }
    @{ Key='Maintenance'; Title='Service resets';    Sub='Restart common Windows services' }
    @{ Key='History';     Title='History';           Sub='Audit log of tool actions' }
    @{ Key='Settings';    Title='Settings';          Sub='Theme, defaults, preferences' }
)

$updateSearch = {
    $q = $SearchBox.Text
    $SearchResults.Items.Clear()
    if ([string]::IsNullOrWhiteSpace($q)) {
        $SearchPopup.IsOpen = $false
        $SearchPlaceholder.Visibility = 'Visible'
        return
    }
    $SearchPlaceholder.Visibility = 'Collapsed'
    $matches = $searchIndex | Where-Object {
        $_.Title -like "*$q*" -or $_.Sub -like "*$q*" -or $_.Key -like "*$q*"
    } | Select-Object -First 10
    foreach ($m in $matches) {
        $sp = New-Object System.Windows.Controls.StackPanel
        $sp.Margin = '6,4'; $sp.Tag = $m.Key
        $t = New-Object System.Windows.Controls.TextBlock
        $t.Text = $m.Title; $t.FontWeight = 'SemiBold'
        $t.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
        [void]$sp.Children.Add($t)
        $s = New-Object System.Windows.Controls.TextBlock
        $s.Text = $m.Sub; $s.FontSize = 11
        $s.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
        [void]$sp.Children.Add($s)
        $item = New-Object System.Windows.Controls.ListBoxItem
        $item.Content = $sp
        $item.Tag = $m.Key
        [void]$SearchResults.Items.Add($item)
    }
    $SearchPopup.IsOpen = ($SearchResults.Items.Count -gt 0)
}

$SearchBox.Add_TextChanged({ & $updateSearch }.GetNewClosure())
$SearchBox.Add_GotFocus({ $SearchPlaceholder.Visibility = 'Collapsed' }.GetNewClosure())
$SearchBox.Add_LostFocus({
    if ([string]::IsNullOrWhiteSpace($SearchBox.Text)) { $SearchPlaceholder.Visibility = 'Visible' }
}.GetNewClosure())

$SearchResults.Add_SelectionChanged({
    $sel = $SearchResults.SelectedItem
    if ($sel -is [System.Windows.Controls.ListBoxItem]) {
        $key = $sel.Tag
        $SearchPopup.IsOpen = $false
        $SearchBox.Clear()
        if ($key) { Show-Page -Key ([string]$key) }
    }
}.GetNewClosure())

# Ctrl+K focuses the search box
$script:Window.Add_PreviewKeyDown({
    param($sender, $e)
    if ($e.Key -eq 'K' -and ([System.Windows.Input.Keyboard]::Modifiers -band [System.Windows.Input.ModifierKeys]::Control)) {
        $SearchBox.Focus() | Out-Null
        $SearchBox.SelectAll()
        $e.Handled = $true
    } elseif ($e.Key -eq 'Escape' -and $SearchPopup.IsOpen) {
        $SearchPopup.IsOpen = $false
        $e.Handled = $true
    }
}.GetNewClosure())
#endregion

#region --- Initial load & show -----------------------------------------------
try {
    Set-AppTheme -Theme $script:Theme -Accent $script:Accent
} catch {
    [System.Windows.MessageBox]::Show(
        "Set-AppTheme failed:`n`n$($_.Exception.Message)`n`n$($_.ScriptStackTrace)",
        "SysAdmin Toolkit - Theme error", 'OK', 'Error') | Out-Null
    throw
}
try {
    Show-Page -Key 'Dashboard'
} catch {
    [System.Windows.MessageBox]::Show(
        "Show-Page failed:`n`n$($_.Exception.Message)`n`n$($_.ScriptStackTrace)",
        "SysAdmin Toolkit - Page error", 'OK', 'Error') | Out-Null
    throw
}

$script:Window.Add_Closed({
    try { $script:RunspacePool.Close(); $script:RunspacePool.Dispose() } catch {}
}.GetNewClosure())

Write-AuditLog -Action 'AppStart' -Details "v$script:AppVersion, PS $($PSVersionTable.PSVersion)"

try {
    [void]$script:Window.ShowDialog()
} catch {
    [System.Windows.MessageBox]::Show(
        "ShowDialog failed (render-time error):`n`n$($_.Exception.Message)`n`nStack:`n$($_.ScriptStackTrace)`n`nInner:`n$($_.Exception.InnerException)",
        "SysAdmin Toolkit v$script:AppVersion - Render error", 'OK', 'Error') | Out-Null
    throw
}
#endregion
