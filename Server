    [void]$hotGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition -Property @{Height='Auto'}))
    [void]$hotGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition))
    $hotCtrls = New-Object System.Windows.Controls.StackPanel
    $hotCtrls.Orientation = 'Horizontal'; $hotCtrls.Margin = '0,0,0,10'
    [System.Windows.Controls.Grid]::SetRow($hotCtrls, 0)
    $hotRefresh = New-Object System.Windows.Controls.Button
    $hotRefresh.Content = 'Refresh'
    $hotRefresh.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$hotCtrls.Children.Add($hotRefresh)
    [void]$hotGrid.Children.Add($hotCtrls)
    $hotData = New-Object System.Windows.Controls.DataGrid
    [System.Windows.Controls.Grid]::SetRow($hotData, 1)
    foreach ($c in @(
        @{H='HotFixID';    B='HotFixID';    W='120'},
        @{H='Description'; B='Description'; W='180'},
        @{H='Installed';   B='InstalledOn'; W='140'},
        @{H='By';          B='InstalledBy'; W='160'},
        @{H='Description'; B='Caption';     W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$hotData.Columns.Add($col)
    }
    [void]$hotGrid.Children.Add($hotData)

    $hotRefresh.Add_Click({
        Set-ButtonBusy -Button $hotRefresh -Busy $true
        Invoke-Async -Script {
            Get-HotFix | Sort-Object InstalledOn -Descending | Select-Object HotFixID, Description, InstalledOn, InstalledBy, Caption
        } -OnComplete {
            param($r)
            Set-ButtonBusy -Button $hotRefresh -Busy $false
            $hotData.ItemsSource = $r
        }.GetNewClosure()
    }.GetNewClosure())
    $tabHot.Content = $hotGrid

    # ---- Health check tab ----
    $tabHealth = New-Object System.Windows.Controls.TabItem
    $tabHealth.Header = 'Health check'
    $healthStack = New-Object System.Windows.Controls.StackPanel
    $healthStack.Margin = '0,10,0,0'
    $healthSub = New-Object System.Windows.Controls.TextBlock
    $healthSub.Text = 'Aggregated checks for common issues.'; $healthSub.Margin = '0,0,0,10'
    $healthSub.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$healthStack.Children.Add($healthSub)
    $healthRunBtn = New-Object System.Windows.Controls.Button
    $healthRunBtn.Content = 'Run health check'; $healthRunBtn.HorizontalAlignment = 'Left'; $healthRunBtn.Margin = '0,0,0,10'
    $healthRunBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$healthStack.Children.Add($healthRunBtn)
    $healthResults = New-Object System.Windows.Controls.StackPanel
    [void]$healthStack.Children.Add($healthResults)

    $healthRunBtn.Add_Click({
        $healthResults.Children.Clear()
        Set-ButtonBusy -Button $healthRunBtn -Busy $true -BusyText 'Running...'
        Invoke-Async -Script {
            $checks = @()
            # Disk space
            Get-CimInstance Win32_LogicalDisk -Filter "DriveType=3" | ForEach-Object {
                $pct = if ($_.Size) { [math]::Round(100 * $_.FreeSpace / $_.Size, 1) } else { 0 }
                $kind = if ($pct -lt 10) { 'Error' } elseif ($pct -lt 20) { 'Warning' } else { 'Success' }
                $checks += [pscustomobject]@{ Name="Disk $($_.DeviceID)"; Kind=$kind;
                    Message="$pct% free ($([math]::Round($_.FreeSpace/1GB,0)) of $([math]::Round($_.Size/1GB,0)) GB)" }
            }
            # Memory
            $os = Get-CimInstance Win32_OperatingSystem
            $cs = Get-CimInstance Win32_ComputerSystem
            $usedPct = [math]::Round(100 * ($cs.TotalPhysicalMemory - ($os.FreePhysicalMemory * 1KB)) / $cs.TotalPhysicalMemory, 1)
            $kind = if ($usedPct -gt 90) { 'Error' } elseif ($usedPct -gt 80) { 'Warning' } else { 'Success' }
            $checks += [pscustomobject]@{ Name='Memory'; Kind=$kind; Message="$usedPct% used" }
            # Pending reboot
            $pending = $false
            if (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending') { $pending = $true }
            if (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired') { $pending = $true }
            $checks += [pscustomobject]@{ Name='Pending reboot'; Kind=(if ($pending) { 'Warning' } else { 'Success' });
                Message=(if ($pending) { 'Reboot required' } else { 'None' }) }
            # Recent critical/errors in System log
            try {
                $errs = @(Get-WinEvent -FilterHashtable @{ LogName='System'; Level=1,2; StartTime=(Get-Date).AddHours(-24) } -MaxEvents 50 -ErrorAction Stop)
                $kind = if ($errs.Count -gt 20) { 'Error' } elseif ($errs.Count -gt 5) { 'Warning' } else { 'Success' }
                $checks += [pscustomobject]@{ Name='System log (24h)'; Kind=$kind; Message="$($errs.Count) errors/critical" }
            } catch {
                $checks += [pscustomobject]@{ Name='System log'; Kind='Warning'; Message="Could not read: $($_.Exception.Message)" }
            }
            # Services that should be running
            $critSvcs = @('Spooler', 'Dnscache', 'LanmanWorkstation', 'LanmanServer', 'Schedule', 'W32Time')
            foreach ($n in $critSvcs) {
                try {
                    $s = Get-Service -Name $n -ErrorAction Stop
                    $kind = if ($s.Status -eq 'Running') { 'Success' } elseif ($s.StartType -eq 'Disabled') { 'Info' } else { 'Warning' }
                    $checks += [pscustomobject]@{ Name="Service: $n"; Kind=$kind; Message="$($s.Status) ($($s.StartType))" }
                } catch {}
            }
            # Uptime sanity
            $up = (Get-Date) - $os.LastBootUpTime
            $kind = if ($up.TotalDays -gt 30) { 'Warning' } else { 'Success' }
            $checks += [pscustomobject]@{ Name='Uptime'; Kind=$kind; Message="$([int]$up.TotalDays)d $($up.Hours)h $($up.Minutes)m" }
            return $checks
        } -OnComplete {
            param($r)
            Set-ButtonBusy -Button $healthRunBtn -Busy $false
            foreach ($c in $r) {
                $brushKey = @{Success='Success';Warning='Warning';Error='Danger';Info='Accent'}[$c.Kind]
                $iconMap  = @{Success=[char]0xE930;Warning=[char]0xE7BA;Error=[char]0xEA39;Info=[char]0xE946}
                $row = New-Object System.Windows.Controls.Grid
                $row.Margin = '0,2'
                [void]$row.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='24'}))
                [void]$row.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='200'}))
                [void]$row.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition))
                $ic = New-Object System.Windows.Controls.TextBlock
                $ic.Text = $iconMap[$c.Kind]; $ic.FontFamily = New-Object System.Windows.Media.FontFamily('Segoe Fluent Icons, Segoe MDL2 Assets')
                $ic.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, $brushKey)
                [System.Windows.Controls.Grid]::SetColumn($ic, 0); [void]$row.Children.Add($ic)
                $n = New-Object System.Windows.Controls.TextBlock; $n.Text = $c.Name
                $n.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
                [System.Windows.Controls.Grid]::SetColumn($n, 1); [void]$row.Children.Add($n)
                $m = New-Object System.Windows.Controls.TextBlock; $m.Text = $c.Message; $m.TextWrapping = 'Wrap'
                $m.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
                [System.Windows.Controls.Grid]::SetColumn($m, 2); [void]$row.Children.Add($m)
                [void]$healthResults.Children.Add($row)
            }
            Write-AuditLog -Action 'HealthCheck' -Details "$($r.Count) checks run"
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $healthRunBtn -Busy $false
            Show-Toast -Message "Health check failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }.GetNewClosure())
    $tabHealth.Content = $healthStack

    [void]$tabs.Items.Add($tabEvents)
    [void]$tabs.Items.Add($tabProc)
    [void]$tabs.Items.Add($tabSvc)
    [void]$tabs.Items.Add($tabHot)
    [void]$tabs.Items.Add($tabHealth)
    [void]$root.Children.Add($tabs)
    return $root
}
#endregion

#region --- AD Users module ---------------------------------------------------
function New-ADUsersPage {
    if (-not $script:HasAD) {
        $note = New-Object System.Windows.Controls.TextBlock
        $note.TextWrapping = 'Wrap'
        $note.Text = 'The ActiveDirectory PowerShell module is not available on this machine. Install RSAT (Remote Server Administration Tools) to use AD features, then restart the toolkit.'
        $note.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
        return (New-PageScroll -Title 'AD Users' -Subtitle 'ActiveDirectory module unavailable.' -Children @((New-Card -Child $note)))
    }

    $root = New-Object System.Windows.Controls.DockPanel
    $header = New-PageHeader -Title 'AD Users' -Subtitle 'Search, inspect, and manage domain user accounts.'
    [System.Windows.Controls.DockPanel]::SetDock($header, 'Top')
    [void]$root.Children.Add($header)

    $tabs = New-Object System.Windows.Controls.TabControl
    $tabs.Background = 'Transparent'; $tabs.BorderThickness = '0'

    # ----- Search / manage tab -----
    $tabMain = New-Object System.Windows.Controls.TabItem
    $tabMain.Header = 'Search & manage'
    $mainGrid = New-Object System.Windows.Controls.Grid
    $mainGrid.Margin = '0,10,0,0'
    [void]$mainGrid.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='*'}))
    [void]$mainGrid.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='380'}))

    # Left: search + results
    $leftGrid = New-Object System.Windows.Controls.Grid
    $leftGrid.Margin = '0,0,10,0'
    [void]$leftGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition -Property @{Height='Auto'}))
    [void]$leftGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition))

    $searchPanel = New-Object System.Windows.Controls.StackPanel
    $searchPanel.Orientation = 'Horizontal'; $searchPanel.Margin = '0,0,0,10'
    $searchTxt = New-Object System.Windows.Controls.TextBox
    $searchTxt.Width = 300; $searchTxt.Margin = '0,0,8,0'
    $searchTxt.ToolTip = 'Name, SamAccountName, email, or employee ID'
    $searchBtn = New-Object System.Windows.Controls.Button
    $searchBtn.Content = 'Search'
    $searchBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $lockedBtn = New-Object System.Windows.Controls.Button
    $lockedBtn.Content = 'Show locked out'; $lockedBtn.Margin = '8,0,0,0'
    $lockedBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $disabledBtn = New-Object System.Windows.Controls.Button
    $disabledBtn.Content = 'Show disabled'; $disabledBtn.Margin = '4,0,0,0'
    $disabledBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$searchPanel.Children.Add($searchTxt); [void]$searchPanel.Children.Add($searchBtn)
    [void]$searchPanel.Children.Add($lockedBtn); [void]$searchPanel.Children.Add($disabledBtn)
    [System.Windows.Controls.Grid]::SetRow($searchPanel, 0)
    [void]$leftGrid.Children.Add($searchPanel)

    $resultsGrid = New-Object System.Windows.Controls.DataGrid
    [System.Windows.Controls.Grid]::SetRow($resultsGrid, 1)
    foreach ($c in @(
        @{H='Name';      B='Name';           W='200'},
        @{H='SAM';       B='SamAccountName'; W='140'},
        @{H='Enabled';   B='Enabled';        W='70'},
        @{H='Locked';    B='LockedOut';      W='70'},
        @{H='Last logon';B='LastLogonDate';  W='140'},
        @{H='Email';     B='EmailAddress';   W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$resultsGrid.Columns.Add($col)
    }
    [void]$leftGrid.Children.Add($resultsGrid)
    [System.Windows.Controls.Grid]::SetColumn($leftGrid, 0)
    [void]$mainGrid.Children.Add($leftGrid)

    # Right: detail / action panel
    $rightCard = New-Object System.Windows.Controls.Border
    $rightCard.SetResourceReference([System.Windows.Controls.Border]::StyleProperty, 'Card')
    $rightScroll = New-Object System.Windows.Controls.ScrollViewer
    $rightScroll.VerticalScrollBarVisibility = 'Auto'
    $rightStack = New-Object System.Windows.Controls.StackPanel
    $rightHeader = New-Object System.Windows.Controls.TextBlock
    $rightHeader.Text = 'Select a user'; $rightHeader.FontSize = 16; $rightHeader.FontWeight = 'SemiBold'
    $rightHeader.Margin = '0,0,0,4'
    $rightHeader.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [void]$rightStack.Children.Add($rightHeader)
    $rightSub = New-Object System.Windows.Controls.TextBlock
    $rightSub.Text = 'Click a user in the list to see details and actions.'
    $rightSub.TextWrapping = 'Wrap'; $rightSub.Margin = '0,0,0,12'
    $rightSub.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$rightStack.Children.Add($rightSub)
    $detailPanel = New-Object System.Windows.Controls.StackPanel
    [void]$rightStack.Children.Add($detailPanel)
    $actionPanel = New-Object System.Windows.Controls.StackPanel
    $actionPanel.Margin = '0,12,0,0'
    [void]$rightStack.Children.Add($actionPanel)
    $rightScroll.Content = $rightStack
    $rightCard.Child = $rightScroll
    [System.Windows.Controls.Grid]::SetColumn($rightCard, 1)
    [void]$mainGrid.Children.Add($rightCard)

    $tabMain.Content = $mainGrid

    # ----- Search logic -----
    $doSearch = {
        param($query)
        $q = $query
        Set-ButtonBusy -Button $searchBtn -Busy $true
        Invoke-Async -Script {
            param($q)
            Import-Module ActiveDirectory -ErrorAction Stop
            $props = 'SamAccountName','Name','Enabled','LockedOut','LastLogonDate','EmailAddress','EmployeeID','UserPrincipalName','DistinguishedName'
            if ([string]::IsNullOrWhiteSpace($q)) {
                return @()
            }
            $filter = "Name -like '*$q*' -or SamAccountName -like '*$q*' -or EmailAddress -like '*$q*' -or EmployeeID -eq '$q' -or UserPrincipalName -like '*$q*'"
            Get-ADUser -Filter $filter -Properties $props -ResultSetSize 200 |
                Select-Object Name, SamAccountName, Enabled, LockedOut, LastLogonDate, EmailAddress, EmployeeID, UserPrincipalName, DistinguishedName
        } -Arguments @($q) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $searchBtn -Busy $false
            $resultsGrid.ItemsSource = $r
            Write-AuditLog -Action 'SearchADUsers' -Target $q -Details "$(@($r).Count) results"
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $searchBtn -Busy $false
            Show-Toast -Message "Search failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }
    $searchBtn.Add_Click({ & $doSearch $searchTxt.Text }.GetNewClosure())
    $searchTxt.Add_KeyDown({ if ($_.Key -eq 'Enter') { & $doSearch $searchTxt.Text } }.GetNewClosure())

    $lockedBtn.Add_Click({
        Set-ButtonBusy -Button $lockedBtn -Busy $true
        Invoke-Async -Script {
            Import-Module ActiveDirectory -ErrorAction Stop
            Search-ADAccount -LockedOut -UsersOnly |
                Get-ADUser -Properties Name, SamAccountName, Enabled, LockedOut, LastLogonDate, EmailAddress, DistinguishedName |
                Select-Object Name, SamAccountName, Enabled, LockedOut, LastLogonDate, EmailAddress, DistinguishedName
        } -OnComplete {
            param($r)
            Set-ButtonBusy -Button $lockedBtn -Busy $false
            $resultsGrid.ItemsSource = $r
            Show-Toast -Message "Locked: $(@($r).Count)" -Kind Info
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $lockedBtn -Busy $false
            Show-Toast -Message "Query failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }.GetNewClosure())

    $disabledBtn.Add_Click({
        Set-ButtonBusy -Button $disabledBtn -Busy $true
        Invoke-Async -Script {
            Import-Module ActiveDirectory -ErrorAction Stop
            Search-ADAccount -AccountDisabled -UsersOnly -ResultPageSize 500 |
                Select-Object Name, SamAccountName, Enabled, LockedOut, LastLogonDate, DistinguishedName -First 500
        } -OnComplete {
            param($r)
            Set-ButtonBusy -Button $disabledBtn -Busy $false
            $resultsGrid.ItemsSource = $r
            Show-Toast -Message "Disabled: $(@($r).Count)" -Kind Info
        }.GetNewClosure()
    }.GetNewClosure())

    # ----- Selection: populate detail pane -----
    $refreshDetail = {
        param($user)
        $detailPanel.Children.Clear()
        $actionPanel.Children.Clear()
        if (-not $user) {
            $rightHeader.Text = 'Select a user'
            $rightSub.Text = 'Click a user in the list to see details and actions.'
            return
        }
        $rightHeader.Text = $user.Name
        $rightSub.Text = $user.SamAccountName

        $addRow = {
            param($label, $value)
            $g = New-Object System.Windows.Controls.Grid
            $g.Margin = '0,3'
            $c0 = New-Object System.Windows.Controls.ColumnDefinition; $c0.Width = '100'
            $c1 = New-Object System.Windows.Controls.ColumnDefinition
            [void]$g.ColumnDefinitions.Add($c0); [void]$g.ColumnDefinitions.Add($c1)
            $l = New-Object System.Windows.Controls.TextBlock; $l.Text = $label; $l.FontSize = 12
            $l.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
            [System.Windows.Controls.Grid]::SetColumn($l, 0); [void]$g.Children.Add($l)
            $v = New-Object System.Windows.Controls.TextBlock; $v.Text = "$value"; $v.FontSize = 12
            $v.TextWrapping = 'Wrap'
            $v.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
            [System.Windows.Controls.Grid]::SetColumn($v, 1); [void]$g.Children.Add($v)
            [void]$detailPanel.Children.Add($g)
        }

        & $addRow 'Enabled' $user.Enabled
        & $addRow 'Locked' $user.LockedOut
        & $addRow 'Last logon' $user.LastLogonDate
        & $addRow 'Email' ($user.EmailAddress)
        & $addRow 'UPN' ($user.UserPrincipalName)
        & $addRow 'Employee ID' ($user.EmployeeID)
        & $addRow 'DN' $user.DistinguishedName

        # Actions
        $wrap = New-Object System.Windows.Controls.WrapPanel
        $mkBtn = {
            param($text, $style, $click)
            $b = New-Object System.Windows.Controls.Button
            $b.Content = $text; $b.Margin = '0,4,6,0'
            $b.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, $style)
            $b.Add_Click($click)
            $b
        }

        $btnUnlock = & $mkBtn 'Unlock' 'AccentBtn' {
            if (-not (Show-Confirm -Message "Unlock $($user.SamAccountName)?")) { return }
            Invoke-Async -Script {
                param($sam)
                Import-Module ActiveDirectory -ErrorAction Stop
                Unlock-ADAccount -Identity $sam
                return "unlocked"
            } -Arguments @($user.SamAccountName) -OnComplete {
                param($r)
                Show-Toast -Message "$($user.SamAccountName) unlocked" -Kind Success
                Write-AuditLog -Action 'UnlockUser' -Target $user.SamAccountName
                & $doSearch $searchTxt.Text
            }.GetNewClosure() -OnError {
                param($e)
                Show-Toast -Message "Unlock failed: $($e.Exception.Message)" -Kind Error
                Write-AuditLog -Action 'UnlockUser' -Target $user.SamAccountName -Result 'FAIL' -Details $e.Exception.Message
            }.GetNewClosure()
        }.GetNewClosure()

        $btnReset = & $mkBtn 'Reset password' 'AccentBtn' {
            $pw = Show-Prompt -Message "New password for $($user.SamAccountName):" -Title 'Reset password' -Password
            if (-not $pw) { return }
            if (-not (Show-Confirm -Message "Reset password for $($user.SamAccountName)? User will be required to change at next logon." -Danger)) { return }
            Invoke-Async -Script {
                param($sam, $secPw)
                Import-Module ActiveDirectory -ErrorAction Stop
                Set-ADAccountPassword -Identity $sam -NewPassword $secPw -Reset -ErrorAction Stop
                Set-ADUser -Identity $sam -ChangePasswordAtLogon $true -ErrorAction Stop
                return "reset"
            } -Arguments @($user.SamAccountName, $pw) -OnComplete {
                param($r)
                Show-Toast -Message "Password reset for $($user.SamAccountName)" -Kind Success
                Write-AuditLog -Action 'ResetPassword' -Target $user.SamAccountName
            }.GetNewClosure() -OnError {
                param($e)
                Show-Toast -Message "Reset failed: $($e.Exception.Message)" -Kind Error
                Write-AuditLog -Action 'ResetPassword' -Target $user.SamAccountName -Result 'FAIL' -Details $e.Exception.Message
            }.GetNewClosure()
        }.GetNewClosure()

        $toggleText = if ($user.Enabled) { 'Disable' } else { 'Enable' }
        $toggleStyle = if ($user.Enabled) { 'DangerBtn' } else { 'AccentBtn' }
        $btnToggle = & $mkBtn $toggleText $toggleStyle {
            $action = if ($user.Enabled) { 'disable' } else { 'enable' }
            if (-not (Show-Confirm -Message "$action $($user.SamAccountName)?" -Danger:($action -eq 'disable'))) { return }
            Invoke-Async -Script {
                param($sam, $action)
                Import-Module ActiveDirectory -ErrorAction Stop
                if ($action -eq 'disable') { Disable-ADAccount -Identity $sam }
                else { Enable-ADAccount -Identity $sam }
                return $action
            } -Arguments @($user.SamAccountName, $action) -OnComplete {
                param($r)
                Show-Toast -Message "$($user.SamAccountName) ${r}d" -Kind Success
                Write-AuditLog -Action ("$r`User") -Target $user.SamAccountName
                & $doSearch $searchTxt.Text
            }.GetNewClosure() -OnError {
                param($e)
                Show-Toast -Message "Action failed: $($e.Exception.Message)" -Kind Error
            }.GetNewClosure()
        }.GetNewClosure()

        $btnForceChange = & $mkBtn 'Force PW change' 'SecondaryBtn' {
            if (-not (Show-Confirm -Message "Require $($user.SamAccountName) to change password at next logon?")) { return }
            Invoke-Async -Script {
                param($sam)
                Import-Module ActiveDirectory -ErrorAction Stop
                Set-ADUser -Identity $sam -ChangePasswordAtLogon $true
            } -Arguments @($user.SamAccountName) -OnComplete {
                Show-Toast -Message 'Change required at next logon' -Kind Success
                Write-AuditLog -Action 'ForcePwChange' -Target $user.SamAccountName
            }.GetNewClosure() -OnError { param($e) Show-Toast -Message "Failed: $($e.Exception.Message)" -Kind Error }.GetNewClosure()
        }.GetNewClosure()

        $btnCopyDN = & $mkBtn 'Copy DN' 'SecondaryBtn' {
            [System.Windows.Clipboard]::SetText($user.DistinguishedName)
            Show-Toast -Message 'DN copied to clipboard' -Kind Info
        }.GetNewClosure()

        $btnGroups = & $mkBtn 'View groups' 'SecondaryBtn' {
            $w = New-Object System.Windows.Window
            $w.Title = "Groups for $($user.SamAccountName)"; $w.Width = 520; $w.Height = 500
            $w.Owner = $script:Window; $w.WindowStartupLocation = 'CenterOwner'
            $w.SetResourceReference([System.Windows.Controls.Control]::BackgroundProperty, 'Bg')
            $w.FontFamily = 'Segoe UI'
            $g = New-Object System.Windows.Controls.Grid; $g.Margin = '16'
            [void]$g.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition -Property @{Height='Auto'}))
            [void]$g.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition))
            $h = New-Object System.Windows.Controls.TextBlock
            $h.Text = "Loading groups..."; $h.Margin = '0,0,0,10'
            $h.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
            [System.Windows.Controls.Grid]::SetRow($h, 0); [void]$g.Children.Add($h)
            $list = New-Object System.Windows.Controls.ListBox
            $list.SetResourceReference([System.Windows.Controls.Control]::BorderBrushProperty, 'EdgeBrush')
            [System.Windows.Controls.Grid]::SetRow($list, 1); [void]$g.Children.Add($list)
            $w.Content = $g
            Invoke-Async -Script {
                param($sam)
                Import-Module ActiveDirectory -ErrorAction Stop
                Get-ADPrincipalGroupMembership -Identity $sam | Select-Object -ExpandProperty Name | Sort-Object
            } -Arguments @($user.SamAccountName) -OnComplete {
                param($r)
                $h.Text = "$(@($r).Count) group(s)"
                foreach ($n in $r) { [void]$list.Items.Add($n) }
            }.GetNewClosure() -OnError {
                param($e)
                $h.Text = "Error: $($e.Exception.Message)"
            }.GetNewClosure()
            [void]$w.Show()
        }.GetNewClosure()

        foreach ($b in @($btnUnlock, $btnReset, $btnToggle, $btnForceChange, $btnGroups, $btnCopyDN)) {
            [void]$wrap.Children.Add($b)
        }
        [void]$actionPanel.Children.Add($wrap)
    }

    $resultsGrid.Add_SelectionChanged({
        & $refreshDetail $resultsGrid.SelectedItem
    }.GetNewClosure())

    # ----- Bulk tab -----
    $tabBulk = New-Object System.Windows.Controls.TabItem
    $tabBulk.Header = 'Bulk operations'
    $bulkStack = New-Object System.Windows.Controls.StackPanel
    $bulkStack.Margin = '0,10,0,0'

    $bulkInfo = New-Object System.Windows.Controls.TextBlock
    $bulkInfo.TextWrapping = 'Wrap'
    $bulkInfo.Text = "Paste a list of SamAccountNames (one per line, or comma separated), then choose an action. Actions use the same confirmations and audit log as single-user operations."
    $bulkInfo.Margin = '0,0,0,10'
    $bulkInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$bulkStack.Children.Add($bulkInfo)

    $bulkBox = New-Object System.Windows.Controls.TextBox
    $bulkBox.AcceptsReturn = $true; $bulkBox.MinHeight = 200; $bulkBox.TextWrapping = 'Wrap'
    $bulkBox.VerticalScrollBarVisibility = 'Auto'
    [void]$bulkStack.Children.Add($bulkBox)

    $bulkBtns = New-Object System.Windows.Controls.WrapPanel
    $bulkBtns.Margin = '0,10,0,10'
    $bunlock = New-Object System.Windows.Controls.Button; $bunlock.Content = 'Bulk unlock'
    $bunlock.Margin = '0,0,6,0'
    $bunlock.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $bdisable = New-Object System.Windows.Controls.Button; $bdisable.Content = 'Bulk disable'
    $bdisable.Margin = '0,0,6,0'
    $bdisable.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'DangerBtn')
    $benable = New-Object System.Windows.Controls.Button; $benable.Content = 'Bulk enable'
    $benable.Margin = '0,0,6,0'
    $benable.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $bforce = New-Object System.Windows.Controls.Button; $bforce.Content = 'Bulk force PW change'
    $bforce.Margin = '0,0,6,0'
    $bforce.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$bulkBtns.Children.Add($bunlock); [void]$bulkBtns.Children.Add($bdisable)
    [void]$bulkBtns.Children.Add($benable); [void]$bulkBtns.Children.Add($bforce)
    [void]$bulkStack.Children.Add($bulkBtns)

    $bulkConsole = New-OutputConsole -MinHeight 160
    [void]$bulkStack.Children.Add($bulkConsole.Border)

    $runBulk = {
        param($actionLabel, $scriptForOne)
        $raw = $bulkBox.Text
        if ([string]::IsNullOrWhiteSpace($raw)) { Show-Toast -Message 'No SAMs provided' -Kind Warning; return }
        $sams = @($raw -split "[`r`n,;\t]+" | ForEach-Object { $_.Trim() } | Where-Object { $_ })
        if ($sams.Count -eq 0) { return }
        if (-not (Show-Confirm -Message "$actionLabel $($sams.Count) user(s)?" -Danger)) { return }
        $bulkConsole.Text.ClearLog()
        $bulkConsole.Text.AppendLog("# $actionLabel on $($sams.Count) users")
        Invoke-Async -Script {
            param($sams, $actionLabel, $scriptForOne)
            Import-Module ActiveDirectory -ErrorAction Stop
            $ok = 0; $fail = 0
            foreach ($sam in $sams) {
                try {
                    & ([scriptblock]::Create($scriptForOne)) $sam
                    Write-Information "[OK]   $sam" -InformationAction Continue
                    $ok++
                } catch {
                    Write-Information "[FAIL] $sam -- $($_.Exception.Message)" -InformationAction Continue
                    $fail++
                }
            }
            [pscustomobject]@{ Label=$actionLabel; OK=$ok; Fail=$fail; Total=$sams.Count }
        } -Arguments @($sams, $actionLabel, $scriptForOne) `
          -OnProgress { param($line) $bulkConsole.Text.AppendLog($line) }.GetNewClosure() `
          -OnComplete {
            param($r)
            $bulkConsole.Text.AppendLog("# Done: $($r.OK) ok, $($r.Fail) failed")
            $tkind = if ($r.Fail -gt 0) { 'Warning' } else { 'Success' }
            Show-Toast -Message "$($r.Label): $($r.OK) ok, $($r.Fail) failed" -Kind $tkind
            Write-AuditLog -Action 'BulkOp' -Target $r.Label -Details "$($r.OK)/$($r.Total) ok"
          }.GetNewClosure() -OnError {
            param($e) $bulkConsole.Text.AppendLog("# ERROR: $($e.Exception.Message)")
          }.GetNewClosure()
    }

    $bunlock.Add_Click({ & $runBulk 'Unlock' 'param($sam) Unlock-ADAccount -Identity $sam -ErrorAction Stop' }.GetNewClosure())
    $bdisable.Add_Click({ & $runBulk 'Disable' 'param($sam) Disable-ADAccount -Identity $sam -ErrorAction Stop' }.GetNewClosure())
    $benable.Add_Click({ & $runBulk 'Enable' 'param($sam) Enable-ADAccount -Identity $sam -ErrorAction Stop' }.GetNewClosure())
    $bforce.Add_Click({ & $runBulk 'Force PW change' 'param($sam) Set-ADUser -Identity $sam -ChangePasswordAtLogon $true -ErrorAction Stop' }.GetNewClosure())

    $tabBulk.Content = $bulkStack

    [void]$tabs.Items.Add($tabMain)
    [void]$tabs.Items.Add($tabBulk)
    [void]$root.Children.Add($tabs)
    return $root
}
#endregion

#region --- AD Computers module -----------------------------------------------
function New-ADComputersPage {
    if (-not $script:HasAD) {
        $note = New-Object System.Windows.Controls.TextBlock
        $note.TextWrapping = 'Wrap'
        $note.Text = 'The ActiveDirectory PowerShell module is not available. Install RSAT to use AD features.'
        $note.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
        return (New-PageScroll -Title 'AD Computers' -Subtitle 'ActiveDirectory module unavailable.' -Children @((New-Card -Child $note)))
    }

    $root = New-Object System.Windows.Controls.DockPanel
    [System.Windows.Controls.DockPanel]::SetDock(($h = (New-PageHeader -Title 'AD Computers' `
        -Subtitle 'Search domain computers, check online status, look up BitLocker, clean stale objects.')), 'Top')
    [void]$root.Children.Add($h)

    $grid = New-Object System.Windows.Controls.Grid
    [void]$grid.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='*'}))
    [void]$grid.ColumnDefinitions.Add((New-Object System.Windows.Controls.ColumnDefinition -Property @{Width='360'}))

    $leftGrid = New-Object System.Windows.Controls.Grid; $leftGrid.Margin = '0,0,10,0'
    [void]$leftGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition -Property @{Height='Auto'}))
    [void]$leftGrid.RowDefinitions.Add((New-Object System.Windows.Controls.RowDefinition))

    $ctrls = New-Object System.Windows.Controls.StackPanel; $ctrls.Orientation = 'Horizontal'; $ctrls.Margin = '0,0,0,10'
    [System.Windows.Controls.Grid]::SetRow($ctrls, 0)
    $searchTxt = New-Object System.Windows.Controls.TextBox
    $searchTxt.Width = 260; $searchTxt.Margin = '0,0,8,0'
    $searchTxt.ToolTip = 'Name or description'
    $searchBtn = New-Object System.Windows.Controls.Button
    $searchBtn.Content = 'Search'
    $searchBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $staleCombo = New-Object System.Windows.Controls.ComboBox
    $staleCombo.Width = 160; $staleCombo.Margin = '8,0,0,0'
    @('All', 'Stale > 30 days', 'Stale > 90 days', 'Stale > 180 days') | ForEach-Object { [void]$staleCombo.Items.Add($_) }
    $staleCombo.SelectedIndex = 0
    $pingAllBtn = New-Object System.Windows.Controls.Button
    $pingAllBtn.Content = 'Ping all shown'
    $pingAllBtn.Margin = '8,0,0,0'
    $pingAllBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$ctrls.Children.Add($searchTxt); [void]$ctrls.Children.Add($searchBtn)
    [void]$ctrls.Children.Add($staleCombo); [void]$ctrls.Children.Add($pingAllBtn)
    [void]$leftGrid.Children.Add($ctrls)

    $data = New-Object System.Windows.Controls.DataGrid
    [System.Windows.Controls.Grid]::SetRow($data, 1)
    foreach ($c in @(
        @{H='Name';       B='Name';            W='160'},
        @{H='Enabled';    B='Enabled';         W='70'},
        @{H='Online';     B='Online';          W='70'},
        @{H='OS';         B='OperatingSystem'; W='220'},
        @{H='Last logon'; B='LastLogonDate';   W='140'},
        @{H='DN';         B='DistinguishedName';W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$data.Columns.Add($col)
    }
    [void]$leftGrid.Children.Add($data)
    [System.Windows.Controls.Grid]::SetColumn($leftGrid, 0); [void]$grid.Children.Add($leftGrid)

    # Right detail pane
    $rightCard = New-Object System.Windows.Controls.Border
    $rightCard.SetResourceReference([System.Windows.Controls.Border]::StyleProperty, 'Card')
    $rightScroll = New-Object System.Windows.Controls.ScrollViewer
    $rightScroll.VerticalScrollBarVisibility = 'Auto'
    $rightStack = New-Object System.Windows.Controls.StackPanel
    $rightHeader = New-Object System.Windows.Controls.TextBlock
    $rightHeader.Text = 'Select a computer'; $rightHeader.FontSize = 16; $rightHeader.FontWeight = 'SemiBold'
    $rightHeader.Margin = '0,0,0,4'
    $rightHeader.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [void]$rightStack.Children.Add($rightHeader)
    $rightSub = New-Object System.Windows.Controls.TextBlock
    $rightSub.Text = 'Click a row to see actions.'; $rightSub.Margin = '0,0,0,12'
    $rightSub.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$rightStack.Children.Add($rightSub)
    $detailPanel = New-Object System.Windows.Controls.StackPanel
    [void]$rightStack.Children.Add($detailPanel)
    $actionPanel = New-Object System.Windows.Controls.StackPanel
    $actionPanel.Margin = '0,12,0,0'
    [void]$rightStack.Children.Add($actionPanel)
    $rightScroll.Content = $rightStack; $rightCard.Child = $rightScroll
    [System.Windows.Controls.Grid]::SetColumn($rightCard, 1); [void]$grid.Children.Add($rightCard)

    $doSearch = {
        $q = $searchTxt.Text
        $staleOpt = $staleCombo.SelectedItem
        Set-ButtonBusy -Button $searchBtn -Busy $true
        Invoke-Async -Script {
            param($q, $staleOpt)
            Import-Module ActiveDirectory -ErrorAction Stop
            $props = 'Name','Enabled','OperatingSystem','OperatingSystemVersion','LastLogonDate','Description','DistinguishedName'
            $filter = if ($q) { "Name -like '*$q*' -or Description -like '*$q*'" } else { 'Name -like "*"' }
            $comps = Get-ADComputer -Filter $filter -Properties $props -ResultSetSize 500
            $cutoff = switch ($staleOpt) {
                'Stale > 30 days'  { (Get-Date).AddDays(-30) }
                'Stale > 90 days'  { (Get-Date).AddDays(-90) }
                'Stale > 180 days' { (Get-Date).AddDays(-180) }
                default { $null }
            }
            if ($cutoff) {
                $comps = $comps | Where-Object { $_.LastLogonDate -and $_.LastLogonDate -lt $cutoff }
            }
            $comps | Select-Object Name, Enabled,
                @{N='Online';E={ '?' }},
                OperatingSystem, OperatingSystemVersion, LastLogonDate, Description, DistinguishedName
        } -Arguments @($q, $staleOpt) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $searchBtn -Busy $false
            $data.ItemsSource = $r
            Write-AuditLog -Action 'SearchADComputers' -Target $q -Details "$(@($r).Count) results"
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $searchBtn -Busy $false
            Show-Toast -Message "Search failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }
    $searchBtn.Add_Click({ & $doSearch }.GetNewClosure())
    $searchTxt.Add_KeyDown({ if ($_.Key -eq 'Enter') { & $doSearch } }.GetNewClosure())
    $staleCombo.Add_SelectionChanged({ & $doSearch }.GetNewClosure())

    $pingAllBtn.Add_Click({
        $items = @($data.ItemsSource)
        if ($items.Count -eq 0) { return }
        if ($items.Count -gt 100 -and -not (Show-Confirm -Message "Ping $($items.Count) hosts? This may take a minute.")) { return }
        Set-ButtonBusy -Button $pingAllBtn -Busy $true -BusyText 'Pinging...'
        $names = @($items | ForEach-Object { $_.Name })
        Invoke-Async -Script {
            param($names, $timeoutMs)
            $results = @{}
            $ping = New-Object System.Net.NetworkInformation.Ping
            foreach ($n in $names) {
                try {
                    $r = $ping.Send($n, $timeoutMs)
                    $results[$n] = if ($r.Status -eq 'Success') { 'Yes' } else { 'No' }
                } catch { $results[$n] = 'No' }
            }
            return $results
        } -Arguments @($names, $script:Config.PingSweepTimeoutMs) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $pingAllBtn -Busy $false
            # Mutate items via a new list so grid updates
            $new = foreach ($i in $items) {
                [pscustomobject]@{
                    Name=$i.Name; Enabled=$i.Enabled; Online=$r[$i.Name]
                    OperatingSystem=$i.OperatingSystem; OperatingSystemVersion=$i.OperatingSystemVersion
                    LastLogonDate=$i.LastLogonDate; Description=$i.Description; DistinguishedName=$i.DistinguishedName
                }
            }
            $data.ItemsSource = $new
            Show-Toast -Message "Ping done for $(@($names).Count) hosts" -Kind Success
        }.GetNewClosure()
    }.GetNewClosure())

    $refreshDetail = {
        param($comp)
        $detailPanel.Children.Clear()
        $actionPanel.Children.Clear()
        if (-not $comp) { $rightHeader.Text = 'Select a computer'; $rightSub.Text = 'Click a row to see actions.'; return }
        $rightHeader.Text = $comp.Name
        $rightSub.Text = $comp.OperatingSystem

        $addRow = {
            param($l, $v)
            $g = New-Object System.Windows.Controls.Grid; $g.Margin = '0,3'
            $c0 = New-Object System.Windows.Controls.ColumnDefinition; $c0.Width = '110'
            $c1 = New-Object System.Windows.Controls.ColumnDefinition
            [void]$g.ColumnDefinitions.Add($c0); [void]$g.ColumnDefinitions.Add($c1)
            $lb = New-Object System.Windows.Controls.TextBlock; $lb.Text = $l; $lb.FontSize = 12
            $lb.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
            [System.Windows.Controls.Grid]::SetColumn($lb, 0); [void]$g.Children.Add($lb)
            $vb = New-Object System.Windows.Controls.TextBlock; $vb.Text = "$v"; $vb.FontSize = 12; $vb.TextWrapping = 'Wrap'
            $vb.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
            [System.Windows.Controls.Grid]::SetColumn($vb, 1); [void]$g.Children.Add($vb)
            [void]$detailPanel.Children.Add($g)
        }
        & $addRow 'Enabled' $comp.Enabled
        & $addRow 'Online' $comp.Online
        & $addRow 'OS' $comp.OperatingSystem
        & $addRow 'OS version' $comp.OperatingSystemVersion
        & $addRow 'Last logon' $comp.LastLogonDate
        & $addRow 'Description' $comp.Description
        & $addRow 'DN' $comp.DistinguishedName

        $wrap = New-Object System.Windows.Controls.WrapPanel
        $mk = {
            param($text, $style, $click)
            $b = New-Object System.Windows.Controls.Button
            $b.Content = $text; $b.Margin = '0,4,6,0'
            $b.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, $style)
            $b.Add_Click($click); $b
        }
        $btnPing = & $mk 'Ping' 'AccentBtn' {
            Invoke-Async -Script {
                param($n, $to)
                $p = New-Object System.Net.NetworkInformation.Ping
                try { ($p.Send($n, $to)).Status } catch { "Error: $($_.Exception.Message)" }
            } -Arguments @($comp.Name, $script:Config.PingSweepTimeoutMs) -OnComplete {
                param($r) Show-Toast -Message "Ping $($comp.Name): $r" -Kind Info
            }.GetNewClosure()
        }.GetNewClosure()
        $btnRemoteCmd = & $mk 'Remote command' 'SecondaryBtn' {
            $cmd = Show-Prompt -Message "Command to run on $($comp.Name):" -Title 'Invoke-Command' -Default 'hostname'
            if (-not $cmd) { return }
            Invoke-Async -Script {
                param($n, $cmd)
                $sb = [scriptblock]::Create($cmd)
                Invoke-Command -ComputerName $n -ScriptBlock $sb -ErrorAction Stop | Out-String
            } -Arguments @($comp.Name, $cmd) -OnComplete {
                param($r)
                $w = New-Object System.Windows.Window
                $w.Title = "Output from $($comp.Name)"; $w.Width = 700; $w.Height = 500
                $w.Owner = $script:Window; $w.SetResourceReference([System.Windows.Controls.Control]::BackgroundProperty, 'Bg')
                $tb = New-Object System.Windows.Controls.TextBox
                $tb.Text = "$r"; $tb.IsReadOnly = $true; $tb.FontFamily = 'Consolas'
                $tb.VerticalScrollBarVisibility = 'Auto'; $tb.HorizontalScrollBarVisibility = 'Auto'
                $tb.TextWrapping = 'NoWrap'
                $w.Content = $tb
                [void]$w.Show()
                Write-AuditLog -Action 'RemoteCommand' -Target $comp.Name -Details $cmd
            }.GetNewClosure() -OnError {
                param($e) Show-Toast -Message "Failed: $($e.Exception.Message)" -Kind Error
            }.GetNewClosure()
        }.GetNewClosure()
        $btnBitLocker = & $mk 'BitLocker recovery' 'SecondaryBtn' {
            Invoke-Async -Script {
                param($dn)
                Import-Module ActiveDirectory -ErrorAction Stop
                Get-ADObject -Filter {objectClass -eq 'msFVE-RecoveryInformation'} -SearchBase $dn -Properties 'msFVE-RecoveryPassword', whenCreated |
                    Select-Object whenCreated, @{N='Password';E={$_.'msFVE-RecoveryPassword'}}
            } -Arguments @($comp.DistinguishedName) -OnComplete {
                param($r)
                if (-not $r -or @($r).Count -eq 0) {
                    Show-Toast -Message 'No BitLocker recovery info in AD' -Kind Info; return
                }
                $w = New-Object System.Windows.Window
                $w.Title = "BitLocker: $($comp.Name)"; $w.Width = 640; $w.Height = 400
                $w.Owner = $script:Window; $w.SetResourceReference([System.Windows.Controls.Control]::BackgroundProperty, 'Bg')
                $lv = New-Object System.Windows.Controls.DataGrid
                $lv.AutoGenerateColumns = $true; $lv.IsReadOnly = $true
                $lv.ItemsSource = $r
                $w.Content = $lv
                [void]$w.Show()
                Write-AuditLog -Action 'BitLockerLookup' -Target $comp.Name
            }.GetNewClosure() -OnError {
                param($e) Show-Toast -Message "Failed: $($e.Exception.Message)" -Kind Error
            }.GetNewClosure()
        }.GetNewClosure()
        $btnReboot = & $mk 'Reboot' 'DangerBtn' {
            if (-not (Show-Confirm -Message "Reboot $($comp.Name)?" -Danger)) { return }
            Invoke-Async -Script {
                param($n)
                Restart-Computer -ComputerName $n -Force -ErrorAction Stop
            } -Arguments @($comp.Name) -OnComplete {
                Show-Toast -Message "$($comp.Name) reboot initiated" -Kind Success
                Write-AuditLog -Action 'RemoteReboot' -Target $comp.Name
            }.GetNewClosure() -OnError {
                param($e) Show-Toast -Message "Reboot failed: $($e.Exception.Message)" -Kind Error
            }.GetNewClosure()
        }.GetNewClosure()
        $btnCopy = & $mk 'Copy DN' 'SecondaryBtn' {
            [System.Windows.Clipboard]::SetText($comp.DistinguishedName)
            Show-Toast -Message 'DN copied' -Kind Info
        }.GetNewClosure()
        foreach ($b in @($btnPing, $btnRemoteCmd, $btnBitLocker, $btnReboot, $btnCopy)) { [void]$wrap.Children.Add($b) }
        [void]$actionPanel.Children.Add($wrap)
    }
    $data.Add_SelectionChanged({ & $refreshDetail $data.SelectedItem }.GetNewClosure())

    [void]$root.Children.Add($grid)
    return $root
}
