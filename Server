    $bgGrid = New-Object System.Windows.Controls.DataGrid
    $bgGrid.Height = 240
    foreach ($c in @(
        @{H='Host';          B='Host';          W='140'},
        @{H='Account';       B='Account';       W='130'},
        @{H='EnabledBefore'; B='EnabledBefore'; W='110'},
        @{H='EnabledAfter';  B='EnabledAfter';  W='110'},
        @{H='PasswordSet';   B='PasswordSet';   W='100'},
        @{H='SafeModeOk';    B='SafeModeOk';    W='100'},
