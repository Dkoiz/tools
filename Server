    $procRefresh = New-Object System.Windows.Controls.Button
    $procRefresh.Content = 'Refresh'
    $procRefresh.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $procKill = New-Object System.Windows.Controls.Button
    $procKill.Content = 'Kill selected'; $procKill.Margin = '8,0,0,0'
    $procKill.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'DangerBtn')
    [void]$procCtrls.Children.Add($procFilter); [void]$procCtrls.Children.Add($procRefresh); [void]$procCtrls.Children.Add($procKill)
    [void]$procGrid.Children.Add($procCtrls)

    $procData = New-Object System.Windows.Controls.DataGrid
    $procData.SelectionMode = 'Extended'
    [System.Windows.Controls.Grid]::SetRow($procData, 1)
    foreach ($c in @(
        @{H='PID';      B='Id';          W='70'},
        @{H='Name';     B='Name';        W='220'},
        @{H='CPU(s)';   B='CPU';         W='80'},
        @{H='Memory';   B='MemoryMB';    W='100'},
        @{H='Threads';  B='Threads';     W='80'},
        @{H='Started';  B='StartTime';   W='140'},
        @{H='Path';     B='Path';        W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$procData.Columns.Add($col)
    }
    [void]$procGrid.Children.Add($procData)

    $loadProcs = {
        $filter = $procFilter.Text
        Set-ButtonBusy -Button $procRefresh -Busy $true
        Invoke-Async -Script {
            param($filter)
            $procs = Get-Process | Select-Object Id, Name,
                @{N='CPU';E={ try { [math]::Round($_.CPU, 1) } catch { 0 } }},
                @{N='MemoryMB';E={ [math]::Round($_.WorkingSet64/1MB,1) }},
                @{N='Threads';E={ $_.Threads.Count }},
                @{N='StartTime';E={ try { $_.StartTime.ToString('HH:mm:ss') } catch { '' } }},
                Path
            if ($filter) { $procs = $procs | Where-Object { $_.Name -like "*$filter*" } }
            $procs | Sort-Object MemoryMB -Descending
        } -Arguments @($filter) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $procRefresh -Busy $false
            $procData.ItemsSource = $r
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $procRefresh -Busy $false
            Show-Toast -Message "Process fetch failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }
    $procRefresh.Add_Click($loadProcs)
    $procFilter.Add_KeyDown({ if ($_.Key -eq 'Enter') { & $loadProcs } }.GetNewClosure())

    $procKill.Add_Click({
        $sel = @($procData.SelectedItems)
        if ($sel.Count -eq 0) { Show-Toast -Message 'Nothing selected' -Kind Warning; return }
        $names = ($sel | Select-Object -First 5 -ExpandProperty Name) -join ', '
        $more = if ($sel.Count -gt 5) { " (+$($sel.Count - 5) more)" } else { '' }
        if (-not (Show-Confirm -Message "Kill $($sel.Count) process(es)?`n`n$names$more" -Title 'Confirm kill' -Danger)) { return }
        $ids = @($sel | ForEach-Object { $_.Id })
        Invoke-Async -Script {
            param($ids)
            foreach ($id in $ids) {
                try { Stop-Process -Id $id -Force -ErrorAction Stop }
                catch { Write-Information "Failed $id`: $($_.Exception.Message)" -InformationAction Continue }
            }
            return $ids.Count
        } -Arguments @(,$ids) -OnComplete {
            param($r)
            Show-Toast -Message "Killed $r process(es)" -Kind Success
