<#
.SYNOPSIS
    SysAdmin Toolkit - a modern WPF GUI for common Active Directory sysadmin tasks.
.DESCRIPTION
    Single-file, zero external dependencies. Runs on Windows PowerShell 5.1 and PowerShell 7+.

    Modules:
      - Dashboard, Diagnostics, AD Users, AD Computers, Network, Remote,
        Maintenance, History, Settings
.NOTES
    Requires Windows (WPF). Many AD features require RSAT ActiveDirectory module.
    The tool degrades gracefully when AD is unavailable.

    Audit log:    %LOCALAPPDATA%\SysAdminToolkit\audit.jsonl
    Config file:  %LOCALAPPDATA%\SysAdminToolkit\config.json
#>

#region --- Bootstrap & prerequisites -----------------------------------------
[CmdletBinding()]
param()

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# WPF requires STA. PowerShell 7 defaults to MTA, so re-launch if needed.
if ([Threading.Thread]::CurrentThread.GetApartmentState() -ne 'STA') {
    Write-Warning "This script must run in STA mode. Relaunching..."
    $psExe = if ($PSVersionTable.PSVersion.Major -ge 6) { 'pwsh' } else { 'powershell' }
    Start-Process $psExe -ArgumentList @('-STA', '-NoProfile', '-File', $PSCommandPath)
    return
}

Add-Type -AssemblyName PresentationFramework
Add-Type -AssemblyName PresentationCore
Add-Type -AssemblyName WindowsBase
Add-Type -AssemblyName System.Windows.Forms
#endregion

#region --- Paths, config, constants ------------------------------------------
$script:AppName    = 'SysAdmin Toolkit'
$script:AppVersion = '1.1.4'
$script:DataDir    = Join-Path $env:LOCALAPPDATA 'SysAdminToolkit'
$script:LogFile    = Join-Path $script:DataDir 'audit.jsonl'
$script:ConfigFile = Join-Path $script:DataDir 'config.json'

if (-not (Test-Path $script:DataDir)) {
    New-Item -Path $script:DataDir -ItemType Directory -Force | Out-Null
}

function Get-DefaultConfig {
    [pscustomobject]@{
        Theme               = 'System'       # System | Light | Dark
        DefaultDomain       = $env:USERDNSDOMAIN
        DefaultDC           = $null
        DefaultUserOU       = $null
        DefaultComputerOU   = $null
        ConfirmDestructive  = $true
        PingSweepTimeoutMs  = 500
        PingSweepMaxThreads = 64
        HistoryInMemoryMax  = 500
    }
}

function Load-Config {
    if (Test-Path $script:ConfigFile) {
        try {
            return (Get-Content $script:ConfigFile -Raw | ConvertFrom-Json)
        } catch {
            Write-Warning "Config file corrupt, using defaults."
        }
    }
    return Get-DefaultConfig
}

function Save-Config {
    param($Config)
    try {
        ($Config | ConvertTo-Json -Depth 4) | Set-Content -Path $script:ConfigFile -Encoding UTF8
    } catch {
        Write-Warning "Could not save config: $_"
    }
}

$script:Config = Load-Config

# Detect whether AD cmdlets are available
function Test-ADAvailable {
    $m = Get-Module -ListAvailable -Name ActiveDirectory -ErrorAction SilentlyContinue
    return [bool]$m
}
$script:HasAD = Test-ADAvailable
if ($script:HasAD) {
    try { Import-Module ActiveDirectory -ErrorAction Stop } catch { $script:HasAD = $false }
}
#endregion

#region --- System theme & accent detection -----------------------------------
function Get-SystemTheme {
    try {
        $key = 'HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize'
        $val = Get-ItemProperty -Path $key -Name 'AppsUseLightTheme' -ErrorAction Stop
        if ($val.AppsUseLightTheme -eq 0) { return 'Dark' } else { return 'Light' }
    } catch {
        return 'Light'
    }
}

function Get-SystemAccent {
    try {
        $key = 'HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Accent'
        $val = Get-ItemProperty -Path $key -Name 'AccentColorMenu' -ErrorAction Stop
        $c = [uint32]$val.AccentColorMenu
        $r = ($c)        -band 0xFF
        $g = ($c -shr 8) -band 0xFF
        $b = ($c -shr 16) -band 0xFF
        return ('#{0:X2}{1:X2}{2:X2}' -f $r, $g, $b)
    } catch {
        return '#0078D4'
    }
}

# Effective theme from config setting
function Resolve-Theme {
    param([string] $Setting = $script:Config.Theme)
    if ($Setting -eq 'System' -or -not $Setting) { return Get-SystemTheme }
    return $Setting
}

$script:Theme  = Resolve-Theme
$script:Accent = Get-SystemAccent
#endregion

