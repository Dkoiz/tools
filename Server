    $svcStatusCombo = New-Object System.Windows.Controls.ComboBox
    $svcStatusCombo.Width = 140; $svcStatusCombo.Margin = '0,0,8,0'
    @('All', 'Running', 'Stopped') | ForEach-Object { [void]$svcStatusCombo.Items.Add($_) }
    $svcStatusCombo.SelectedIndex = 0
    $svcRefresh = New-Object System.Windows.Controls.Button
    $svcRefresh.Content = 'Refresh'
    $svcRefresh.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    $svcStart = New-Object System.Windows.Controls.Button; $svcStart.Content = 'Start'
    $svcStart.Margin = '8,0,0,0'; $svcStart.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $svcStop = New-Object System.Windows.Controls.Button; $svcStop.Content = 'Stop'
    $svcStop.Margin = '4,0,0,0'; $svcStop.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $svcRestart = New-Object System.Windows.Controls.Button; $svcRestart.Content = 'Restart'
    $svcRestart.Margin = '4,0,0,0'; $svcRestart.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    [void]$svcCtrls.Children.Add($svcFilter); [void]$svcCtrls.Children.Add($svcStatusCombo); [void]$svcCtrls.Children.Add($svcRefresh)
    [void]$svcCtrls.Children.Add($svcStart); [void]$svcCtrls.Children.Add($svcStop); [void]$svcCtrls.Children.Add($svcRestart)
    [void]$svcGrid.Children.Add($svcCtrls)

    $svcData = New-Object System.Windows.Controls.DataGrid
    [System.Windows.Controls.Grid]::SetRow($svcData, 1)
    foreach ($c in @(
        @{H='Name';     B='Name';        W='200'},
        @{H='Display';  B='DisplayName'; W='*'},
        @{H='Status';   B='Status';      W='100'},
        @{H='Startup';  B='StartType';   W='120'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$svcData.Columns.Add($col)
    }
    [void]$svcGrid.Children.Add($svcData)

    $loadSvcs = {
        $filter = $svcFilter.Text
        $status = $svcStatusCombo.SelectedItem
        Set-ButtonBusy -Button $svcRefresh -Busy $true
        Invoke-Async -Script {
            param($filter, $status)
            $s = Get-Service | Select-Object Name, DisplayName, Status, StartType
            if ($filter) { $s = $s | Where-Object { $_.Name -like "*$filter*" -or $_.DisplayName -like "*$filter*" } }
            if ($status -ne 'All') { $s = $s | Where-Object { $_.Status -eq $status } }
            $s | Sort-Object DisplayName
        } -Arguments @($filter, $status) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $svcRefresh -Busy $false
            $svcData.ItemsSource = $r
        }.GetNewClosure()
