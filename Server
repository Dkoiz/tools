function New-OutputConsole {
    param([int] $MinHeight = 200)
    $b = New-Object System.Windows.Controls.Border
    $b.CornerRadius = 6
    $b.SetResourceReference([System.Windows.Controls.Border]::BackgroundProperty, 'Console')
    $b.Padding = '10'
    $tb = New-Object System.Windows.Controls.TextBox
    $tb.IsReadOnly = $true
    $tb.BorderThickness = '0'
    $tb.Background = 'Transparent'
    $tb.SetResourceReference([System.Windows.Controls.TextBox]::ForegroundProperty, 'ConsoleText')
    $tb.FontFamily = 'Consolas, Courier New'
    $tb.FontSize = 12
    $tb.TextWrapping = 'NoWrap'
    $tb.VerticalScrollBarVisibility = 'Auto'
    $tb.HorizontalScrollBarVisibility = 'Auto'
    $tb.MinHeight = $MinHeight
    $tb.MaxHeight = 400
    $b.Child = $tb
    # Attach a helper as a NoteProperty so callers can do $console.AppendLog("...")
    $append = {
        param($txt)
        $this.Dispatcher.Invoke([action]{
            $this.AppendText("$txt`r`n")
            $this.ScrollToEnd()
        })
    }
    $tb | Add-Member -MemberType ScriptMethod -Name AppendLog -Value $append -Force
    $tb | Add-Member -MemberType ScriptMethod -Name ClearLog -Value { $this.Clear() } -Force
    [pscustomobject]@{ Border = $b; Text = $tb }
}
$script:BtnOrigContent = @{}
function Set-ButtonBusy {
    param([System.Windows.Controls.Button] $Button, [bool] $Busy, [string] $BusyText = 'Working...')
    $key = $Button.GetHashCode().ToString()
    if ($Busy) {
        if (-not $script:BtnOrigContent.ContainsKey($key)) {
            $script:BtnOrigContent[$key] = $Button.Content
        }
        $Button.Content = $BusyText
        $Button.IsEnabled = $false
    } else {
        if ($script:BtnOrigContent.ContainsKey($key)) {
            $Button.Content = $script:BtnOrigContent[$key]
            [void]$script:BtnOrigContent.Remove($key)
        }
        $Button.IsEnabled = $true
    }
}
#endregion

#region --- Dashboard module --------------------------------------------------
function New-DashboardPage {
    $scroll = New-Object System.Windows.Controls.ScrollViewer
    $scroll.VerticalScrollBarVisibility = 'Auto'
    $stack = New-Object System.Windows.Controls.StackPanel
    [void]$stack.Children.Add((New-PageHeader -Title 'Dashboard' `
        -Subtitle "Welcome, $env:USERNAME. Overview of $env:COMPUTERNAME."))

    # Tile row
    $tiles = New-Object System.Windows.Controls.Primitives.UniformGrid
    $tiles.Columns = 4; $tiles.Margin = '0,0,0,12'

    $makeTile = {
        param($label, $value, $icon, $tag)
        $b = New-Object System.Windows.Controls.Border
        $b.SetResourceReference([System.Windows.Controls.Border]::StyleProperty, 'Card')
        $b.Margin = '0,0,12,12'; $b.MinHeight = 96
        $st = New-Object System.Windows.Controls.StackPanel
        $ic = New-Object System.Windows.Controls.TextBlock
        $ic.Text = $icon
        $ic.FontFamily = New-Object System.Windows.Media.FontFamily('Segoe Fluent Icons, Segoe MDL2 Assets')
        $ic.FontSize = 20
        $ic.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'Accent')
        [void]$st.Children.Add($ic)
        $vv = New-Object System.Windows.Controls.TextBlock
        $vv.Text = $value; $vv.FontSize = 20; $vv.FontWeight = 'SemiBold'; $vv.Margin = '0,8,0,2'
        $vv.TextTrimming = 'CharacterEllipsis'
        $vv.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
        [void]$st.Children.Add($vv)
        $ll = New-Object System.Windows.Controls.TextBlock
        $ll.Text = $label; $ll.FontSize = 12
        $ll.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
        [void]$st.Children.Add($ll)
        $b.Child = $st
        # Return both the Border (to add to UI) and the value TextBlock (to update later).
        return [pscustomobject]@{ Border = $b; Value = $vv }
    }

    $dom = if ($env:USERDNSDOMAIN) { $env:USERDNSDOMAIN } else { $env:USERDOMAIN }
    $hostTile    = & $makeTile 'Hostname'     $env:COMPUTERNAME                    ([char]0xE977) 'host'
    $domainTile  = & $makeTile 'Domain'       $dom                                 ([char]0xE968) 'dom'
    $userTile    = & $makeTile 'User'         $env:USERNAME                        ([char]0xE716) 'user'
    $psTile      = & $makeTile 'PowerShell'   $PSVersionTable.PSVersion.ToString() ([char]0xE756) 'ps'
    [void]$tiles.Children.Add($hostTile.Border); [void]$tiles.Children.Add($domainTile.Border)
    [void]$tiles.Children.Add($userTile.Border); [void]$tiles.Children.Add($psTile.Border)

    # Second row - live values (loaded async)
    $tiles2 = New-Object System.Windows.Controls.Primitives.UniformGrid
    $tiles2.Columns = 4; $tiles2.Margin = '0,0,0,12'
    $uptimeTile = & $makeTile 'Uptime'        'Loading...' ([char]0xE823) 'uptime'
    $cpuTile    = & $makeTile 'CPU load'      'Loading...' ([char]0xE950) 'cpu'
    $memTile    = & $makeTile 'Memory'        'Loading...' ([char]0xEEA3) 'mem'
    $diskTile   = & $makeTile 'System disk'   'Loading...' ([char]0xEDA2) 'disk'
    [void]$tiles2.Children.Add($uptimeTile.Border); [void]$tiles2.Children.Add($cpuTile.Border)
    [void]$tiles2.Children.Add($memTile.Border);    [void]$tiles2.Children.Add($diskTile.Border)

    [void]$stack.Children.Add($tiles); [void]$stack.Children.Add($tiles2)

    # Status card - AD / pending reboot / updates
    $statusStack = New-Object System.Windows.Controls.StackPanel
    $statusHeader = New-Object System.Windows.Controls.TextBlock
    $statusHeader.Text = 'System status'; $statusHeader.FontSize = 15; $statusHeader.FontWeight = 'SemiBold'
    $statusHeader.Margin = '0,0,0,8'
    $statusHeader.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [void]$statusStack.Children.Add($statusHeader)

    $makeStatusLine = {
        param($label, $value, $tag)
        $g = New-Object System.Windows.Controls.Grid; $g.Margin = '0,2'
        $c0 = New-Object System.Windows.Controls.ColumnDefinition; $c0.Width = '180'
        $c1 = New-Object System.Windows.Controls.ColumnDefinition
        [void]$g.ColumnDefinitions.Add($c0); [void]$g.ColumnDefinitions.Add($c1)
        $l = New-Object System.Windows.Controls.TextBlock
        $l.Text = $label
        $l.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
        [System.Windows.Controls.Grid]::SetColumn($l, 0); [void]$g.Children.Add($l)
        $v = New-Object System.Windows.Controls.TextBlock
        $v.Text = $value
        $v.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
        [System.Windows.Controls.Grid]::SetColumn($v, 1); [void]$g.Children.Add($v)
        return [pscustomobject]@{ Grid = $g; Value = $v }
    }
    $adMsg = if ($script:HasAD) { 'Module available, querying...' } else { 'RSAT not installed' }
    $lineAD      = & $makeStatusLine 'Active Directory' $adMsg 'ad'
    $lineReboot  = & $makeStatusLine 'Pending reboot'    'Checking...' 'reboot'
    $lineUpdates = & $makeStatusLine 'Windows Update'    'Checking...' 'updates'
    $lineLogon   = & $makeStatusLine 'Last boot'         'Checking...' 'boot'
    [void]$statusStack.Children.Add($lineAD.Grid)
    [void]$statusStack.Children.Add($lineReboot.Grid)
    [void]$statusStack.Children.Add($lineUpdates.Grid)
    [void]$statusStack.Children.Add($lineLogon.Grid)
    [void]$stack.Children.Add((New-Card -Child $statusStack))

    # Quick actions card
    $qaStack = New-Object System.Windows.Controls.StackPanel
    $qaHeader = New-Object System.Windows.Controls.TextBlock
    $qaHeader.Text = 'Quick actions'; $qaHeader.FontSize = 15; $qaHeader.FontWeight = 'SemiBold'
    $qaHeader.Margin = '0,0,0,10'
    $qaHeader.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [void]$qaStack.Children.Add($qaHeader)

    $wrap = New-Object System.Windows.Controls.WrapPanel
    foreach ($pair in @(
        @('Unlock a user',    'ADUsers'),
        @('Check a computer', 'ADComputers'),
        @('Ping sweep',       'Network'),
        @('Remote command',   'Remote'),
        @('Disk cleanup',     'Maintenance'),
        @('Event logs',       'Diagnostics')
    )) {
        $btn = New-Object System.Windows.Controls.Button
        $btn.Content = $pair[0]; $btn.Margin = '0,0,8,8'
        $btn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
        $target = $pair[1]
        $btn.Add_Click({ Show-Page -Key $target }.GetNewClosure())
        [void]$wrap.Children.Add($btn)
    }
    [void]$qaStack.Children.Add($wrap)
    [void]$stack.Children.Add((New-Card -Child $qaStack))

    $scroll.Content = $stack

    # Async load live values
    Invoke-Async -Script {
        $os = Get-CimInstance Win32_OperatingSystem
        $cs = Get-CimInstance Win32_ComputerSystem
        $cpu = Get-CimInstance Win32_Processor | Select-Object -First 1
        $disk = Get-CimInstance Win32_LogicalDisk -Filter "DeviceID='$($env:SystemDrive)'"

        $uptime = (Get-Date) - $os.LastBootUpTime
        $uptimeStr = "{0}d {1}h {2}m" -f [int]$uptime.TotalDays, $uptime.Hours, $uptime.Minutes

        $memTotalGB = [math]::Round($cs.TotalPhysicalMemory / 1GB, 1)
        $memFreeGB  = [math]::Round($os.FreePhysicalMemory / 1MB, 1)
        $memUsedGB  = [math]::Round($memTotalGB - $memFreeGB, 1)

        $diskTotalGB = if ($disk) { [math]::Round($disk.Size / 1GB, 0) } else { 0 }
        $diskFreeGB  = if ($disk) { [math]::Round($disk.FreeSpace / 1GB, 0) } else { 0 }

        # Pending reboot check - several known indicators
        $pending = $false
        $reasons = @()
        if (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending') {
            $pending = $true; $reasons += 'CBS'
        }
        if (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired') {
            $pending = $true; $reasons += 'Windows Update'
        }
        try {
            $pnr = Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager' -Name 'PendingFileRenameOperations' -ErrorAction Stop
            if ($pnr.PendingFileRenameOperations) { $pending = $true; $reasons += 'PendingRename' }
        } catch {}

        # Windows Update recent status
        $wu = 'Unknown'
        try {
            $s = Get-Service -Name wuauserv -ErrorAction Stop
            $wu = "Service: $($s.Status)"
        } catch {}

        [pscustomobject]@{
            Uptime  = $uptimeStr
            CPU     = "$($cpu.Name.Trim())"
            Mem     = "$memUsedGB / $memTotalGB GB"
            Disk    = "$diskFreeGB / $diskTotalGB GB free"
            Boot    = $os.LastBootUpTime.ToString('yyyy-MM-dd HH:mm')
            Pending = if ($pending) { "Yes ($($reasons -join ', '))" } else { 'No' }
            WU      = $wu
        }
    } -OnComplete {
        param($r)
        if (-not $r) { return }
        $uptimeTile.Value.Text = $r.Uptime
        $cpuTile.Value.Text    = $r.CPU
        $memTile.Value.Text    = $r.Mem
        $diskTile.Value.Text   = $r.Disk
        $lineReboot.Value.Text  = $r.Pending
        $lineUpdates.Value.Text = $r.WU
        $lineLogon.Value.Text   = $r.Boot
    }.GetNewClosure() -OnError {
        param($e)
        Show-Toast -Message "Could not load system info: $e" -Kind Warning
    }.GetNewClosure()

    # AD reachability check (fire-and-forget)
    if ($script:HasAD) {
        Invoke-Async -Script {
            try {
                $d = Get-ADDomain -ErrorAction Stop
                $dc = Get-ADDomainController -Discover -ErrorAction Stop
                return "Online - $($d.DNSRoot) via $($dc.HostName)"
            } catch {
                return "Unreachable: $($_.Exception.Message)"
            }
        } -OnComplete {
            param($r)
            $lineAD.Value.Text = $r
        }.GetNewClosure()
    }

    return $scroll
}
