    $bgRow = New-Object System.Windows.Controls.StackPanel
    $bgRow.Orientation = 'Horizontal'; $bgRow.Margin = '0,0,0,10'
    $bgVerifyBtn = New-Object System.Windows.Controls.Button
    $bgVerifyBtn.Content = 'Verify only (no changes)'; $bgVerifyBtn.Margin = '0,0,8,0'
    $bgVerifyBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'SecondaryBtn')
    $bgApplyBtn = New-Object System.Windows.Controls.Button
    $bgApplyBtn.Content = 'Apply (rotate password)'
    $bgApplyBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'DangerBtn')
    [void]$bgRow.Children.Add($bgVerifyBtn); [void]$bgRow.Children.Add($bgApplyBtn)
