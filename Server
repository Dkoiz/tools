    $svcRefresh.Add_Click($loadSvcs)
    $svcFilter.Add_KeyDown({ if ($_.Key -eq 'Enter') { & $loadSvcs } }.GetNewClosure())
    $svcStatusCombo.Add_SelectionChanged({ & $loadSvcs }.GetNewClosure())

    $svcAction = {
        param($action)
        $sel = @($svcData.SelectedItems)
        if ($sel.Count -eq 0) { Show-Toast -Message 'No service selected' -Kind Warning; return }
        $names = @($sel | ForEach-Object { $_.Name })
        if (-not (Show-Confirm -Message "$action $($sel.Count) service(s)?`n`n$($names -join ', ')")) { return }
        Invoke-Async -Script {
            param($action, $names)
            $ok = 0; $fail = 0
            foreach ($n in $names) {
                try {
                    switch ($action) {
                        'Start'   { Start-Service -Name $n -ErrorAction Stop }
                        'Stop'    { Stop-Service  -Name $n -Force -ErrorAction Stop }
                        'Restart' { Restart-Service -Name $n -Force -ErrorAction Stop }
                    }
                    $ok++
                } catch { $fail++ }
            }
            [pscustomobject]@{ OK=$ok; Fail=$fail }
        } -Arguments @($action, $names) -OnComplete {
            param($r)
            $tkind = if ($r.Fail -gt 0) { 'Warning' } else { 'Success' }
            Show-Toast -Message "$action complete: $($r.OK) ok, $($r.Fail) failed" -Kind $tkind
            Write-AuditLog -Action "Service$action" -Target ($names -join ',') -Details "$($r.OK) ok, $($r.Fail) failed"
            & $loadSvcs
        }.GetNewClosure()
    }
    $svcStart.Add_Click({ & $svcAction 'Start' }.GetNewClosure())
    $svcStop.Add_Click({ & $svcAction 'Stop' }.GetNewClosure())
    $svcRestart.Add_Click({ & $svcAction 'Restart' }.GetNewClosure())

    $tabSvc.Content = $svcGrid

    # ---- Hotfixes tab ----
    $tabHot = New-Object System.Windows.Controls.TabItem
    $tabHot.Header = 'Hotfixes'
