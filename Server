#region --- Network module ----------------------------------------------------
function New-NetworkPage {
    $root = New-Object System.Windows.Controls.DockPanel
    [System.Windows.Controls.DockPanel]::SetDock(($h = (New-PageHeader -Title 'Network' `
        -Subtitle 'Ping sweep, DNS lookups, port checks, trace route, IP configuration.')), 'Top')
    [void]$root.Children.Add($h)

    $tabs = New-Object System.Windows.Controls.TabControl
    $tabs.Background = 'Transparent'; $tabs.BorderThickness = '0'

    # ----- Ping sweep -----
    $tabSweep = New-Object System.Windows.Controls.TabItem
    $tabSweep.Header = 'Ping sweep'
    $sweepStack = New-Object System.Windows.Controls.StackPanel
    $sweepStack.Margin = '0,10,0,0'
    $sweepInfo = New-Object System.Windows.Controls.TextBlock
    $sweepInfo.TextWrapping = 'Wrap'
    $sweepInfo.Text = 'Enter a CIDR (e.g. 192.168.1.0/24), an IP range (192.168.1.1-192.168.1.50), or comma-separated hosts.'
    $sweepInfo.Margin = '0,0,0,10'
    $sweepInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
    [void]$sweepStack.Children.Add($sweepInfo)

    $sweepCtrls = New-Object System.Windows.Controls.StackPanel
    $sweepCtrls.Orientation = 'Horizontal'; $sweepCtrls.Margin = '0,0,0,10'
    $sweepIn = New-Object System.Windows.Controls.TextBox
    $sweepIn.Width = 320; $sweepIn.Margin = '0,0,8,0'
    $sweepIn.Text = ''
    $sweepResolve = New-Object System.Windows.Controls.CheckBox
    $sweepResolve.Content = 'Resolve names'; $sweepResolve.IsChecked = $true; $sweepResolve.Margin = '0,0,12,0'
    $sweepResolve.VerticalAlignment = 'Center'
    $sweepBtn = New-Object System.Windows.Controls.Button
    $sweepBtn.Content = 'Start'
    $sweepBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$sweepCtrls.Children.Add($sweepIn); [void]$sweepCtrls.Children.Add($sweepResolve); [void]$sweepCtrls.Children.Add($sweepBtn)
    [void]$sweepStack.Children.Add($sweepCtrls)

    $sweepProg = New-Object System.Windows.Controls.ProgressBar
    $sweepProg.Height = 6; $sweepProg.Margin = '0,0,0,8'; $sweepProg.Minimum = 0; $sweepProg.Maximum = 100
    [void]$sweepStack.Children.Add($sweepProg)

    $sweepData = New-Object System.Windows.Controls.DataGrid
    $sweepData.Height = 340
    foreach ($c in @(
        @{H='IP';     B='IP';     W='160'},
        @{H='Status'; B='Status'; W='100'},
        @{H='Time';   B='RttMs';  W='80'},
        @{H='Host';   B='Hostname'; W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$sweepData.Columns.Add($col)
    }
    [void]$sweepStack.Children.Add($sweepData)

    $sweepBtn.Add_Click({
        $txt = $sweepIn.Text
        if ([string]::IsNullOrWhiteSpace($txt)) { Show-Toast -Message 'Enter hosts' -Kind Warning; return }
        Set-ButtonBusy -Button $sweepBtn -Busy $true -BusyText 'Sweeping...'
        $sweepData.ItemsSource = $null
        $sweepProg.Value = 0
        $resolve = [bool]$sweepResolve.IsChecked

        Invoke-Async -Script {
            param($txt, $timeout, $maxThreads, $resolve)
            # Expand input into a list of targets
            $targets = New-Object System.Collections.Generic.List[string]
            foreach ($part in ($txt -split '[,\s]+' | Where-Object { $_ })) {
                if ($part -match '^(\d+\.\d+\.\d+\.\d+)/(\d+)$') {
                    $ip = [System.Net.IPAddress]::Parse($Matches[1])
                    $bits = [int]$Matches[2]
                    $maskInt = if ($bits -eq 0) { 0 } else { [uint32]([uint32]0xFFFFFFFF -shl (32 - $bits)) }
                    $ipBytes = $ip.GetAddressBytes(); [Array]::Reverse($ipBytes)
                    $ipInt = [BitConverter]::ToUInt32($ipBytes, 0)
                    $network = $ipInt -band $maskInt
                    $broadcast = $network -bor (-bnot $maskInt -band 0xFFFFFFFF)
                    $start = if ($bits -lt 31) { $network + 1 } else { $network }
                    $end = if ($bits -lt 31) { $broadcast - 1 } else { $broadcast }
                    for ($i = $start; $i -le $end; $i++) {
                        $b = [BitConverter]::GetBytes([uint32]$i); [Array]::Reverse($b)
                        $targets.Add(([System.Net.IPAddress]::new($b)).ToString())
                    }
                } elseif ($part -match '^(\d+\.\d+\.\d+\.\d+)-(\d+\.\d+\.\d+\.\d+)$') {
                    $a = [System.Net.IPAddress]::Parse($Matches[1]).GetAddressBytes(); [Array]::Reverse($a)
                    $z = [System.Net.IPAddress]::Parse($Matches[2]).GetAddressBytes(); [Array]::Reverse($z)
                    $ai = [BitConverter]::ToUInt32($a, 0); $zi = [BitConverter]::ToUInt32($z, 0)
                    for ($i = $ai; $i -le $zi; $i++) {
                        $b = [BitConverter]::GetBytes([uint32]$i); [Array]::Reverse($b)
                        $targets.Add(([System.Net.IPAddress]::new($b)).ToString())
                    }
                } else {
                    $targets.Add($part)
                }
            }

            $total = $targets.Count
            Write-Information "TOTAL:$total" -InformationAction Continue

            # Fire pings in batches using SendPingAsync, which returns Task<PingReply>.
            # We process in batches so we don't open too many sockets at once.
            $rows = New-Object System.Collections.Generic.List[object]
            $batchSize = [math]::Max(1, [math]::Min($maxThreads, $total))
            $processed = 0
            for ($i = 0; $i -lt $total; $i += $batchSize) {
                $end = [math]::Min($i + $batchSize - 1, $total - 1)
                $batch = New-Object System.Collections.Generic.List[object]
                for ($j = $i; $j -le $end; $j++) {
                    $ip = $targets[$j]
                    $ping = New-Object System.Net.NetworkInformation.Ping
                    try {
                        $task = $ping.SendPingAsync($ip, $timeout)
                        $batch.Add([pscustomobject]@{ IP=$ip; Task=$task; Ping=$ping; Err=$null })
                    } catch {
                        $batch.Add([pscustomobject]@{ IP=$ip; Task=$null; Ping=$ping; Err=$_.Exception.Message })
                    }
                }
                # Wait for this batch's tasks, with a generous timeout
                $batchTasks = @($batch | Where-Object { $_.Task } | ForEach-Object { $_.Task })
                if ($batchTasks.Count -gt 0) {
                    try { [void][System.Threading.Tasks.Task]::WaitAll($batchTasks, [int]($timeout * 3)) } catch {}
                }
                foreach ($item in $batch) {
                    if ($item.Err) {
                        $rows.Add([pscustomobject]@{ IP=$item.IP; Status='Error'; RttMs=''; Hostname=$item.Err })
                    } else {
                        try {
                            $reply = $item.Task.Result
                            $hostname = ''
                            if ($resolve -and $reply.Status -eq 'Success') {
                                try { $hostname = [System.Net.Dns]::GetHostEntry($item.IP).HostName } catch {}
                            }
                            $rttStr = if ($reply.Status -eq 'Success') { "$($reply.RoundtripTime) ms" } else { '' }
                            $rows.Add([pscustomobject]@{
                                IP       = $item.IP
                                Status   = "$($reply.Status)"
                                RttMs    = $rttStr
                                Hostname = $hostname
                            })
                        } catch {
                            $rows.Add([pscustomobject]@{ IP=$item.IP; Status='Error'; RttMs=''; Hostname=$_.Exception.Message })
                        }
                    }
                    try { $item.Ping.Dispose() } catch {}
                }
                $processed += $batch.Count
                Write-Information "PROGRESS:$processed" -InformationAction Continue
            }

            # Sort by numeric IP where possible
            $list = @($rows) | Sort-Object {
                try {
                    $bytes = [System.Net.IPAddress]::Parse($_.IP).GetAddressBytes()
                    ($bytes | ForEach-Object { $_.ToString('000') }) -join '.'
                } catch { $_.IP }
            }
            return $list
        } -Arguments @($txt, $script:Config.PingSweepTimeoutMs, $script:Config.PingSweepMaxThreads, $resolve) `
          -OnProgress {
            param($line)
            if ($line -match '^TOTAL:(\d+)$') { $sweepProg.Maximum = [int]$Matches[1] }
            elseif ($line -match '^PROGRESS:(\d+)$') { $sweepProg.Value = [int]$Matches[1] }
          }.GetNewClosure() `
          -OnComplete {
            param($r)
            Set-ButtonBusy -Button $sweepBtn -Busy $false
            $sweepProg.Value = $sweepProg.Maximum
            $sweepData.ItemsSource = $r
            $up = @($r | Where-Object { $_.Status -eq 'Success' }).Count
            Show-Toast -Message "Sweep complete: $up of $(@($r).Count) up" -Kind Success
            Write-AuditLog -Action 'PingSweep' -Target $txt -Details "$up/$(@($r).Count) up"
          }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $sweepBtn -Busy $false
            Show-Toast -Message "Sweep failed: $($e.Exception.Message)" -Kind Error
          }.GetNewClosure()
    }.GetNewClosure())
    $tabSweep.Content = $sweepStack

    # ----- Port check -----
    $tabPort = New-Object System.Windows.Controls.TabItem
    $tabPort.Header = 'Port check'
    $portStack = New-Object System.Windows.Controls.StackPanel
    $portStack.Margin = '0,10,0,0'

    $portRow = New-Object System.Windows.Controls.StackPanel
    $portRow.Orientation = 'Horizontal'; $portRow.Margin = '0,0,0,10'
    $portHost = New-Object System.Windows.Controls.TextBox
    $portHost.Width = 220; $portHost.Margin = '0,0,8,0'
    $portHost.ToolTip = 'Hostname or IP'
    $portPorts = New-Object System.Windows.Controls.TextBox
    $portPorts.Width = 240; $portPorts.Margin = '0,0,8,0'
    $portPorts.Text = '22, 80, 443, 3389, 445, 135, 139, 5985, 5986'
    $portBtn = New-Object System.Windows.Controls.Button
    $portBtn.Content = 'Check'
    $portBtn.SetResourceReference([System.Windows.Controls.Button]::StyleProperty, 'AccentBtn')
    [void]$portRow.Children.Add($portHost); [void]$portRow.Children.Add($portPorts); [void]$portRow.Children.Add($portBtn)
    [void]$portStack.Children.Add($portRow)

    $portData = New-Object System.Windows.Controls.DataGrid
    $portData.Height = 340
    foreach ($c in @(
        @{H='Port'; B='Port'; W='80'},
        @{H='Open'; B='Open'; W='80'},
        @{H='Time'; B='TimeMs'; W='100'},
        @{H='Note'; B='Note'; W='*'}
    )) {
        $col = New-Object System.Windows.Controls.DataGridTextColumn
        $col.Header = $c.H
        $col.Binding = New-Object System.Windows.Data.Binding($c.B)
        if ($c.W -eq '*') { $col.Width = New-Object System.Windows.Controls.DataGridLength(1, 'Star') }
        else { $col.Width = [double]$c.W }
        [void]$portData.Columns.Add($col)
    }
    [void]$portStack.Children.Add($portData)

    $portBtn.Add_Click({
        $h = $portHost.Text.Trim()
        $pstr = $portPorts.Text.Trim()
        if (-not $h -or -not $pstr) { Show-Toast -Message 'Host and ports required' -Kind Warning; return }
        $ports = @($pstr -split '[,;\s]+' | Where-Object { $_ -match '^\d+$' } | ForEach-Object { [int]$_ })
        if ($ports.Count -eq 0) { Show-Toast -Message 'No valid ports' -Kind Warning; return }
        Set-ButtonBusy -Button $portBtn -Busy $true -BusyText 'Checking...'
        $portData.ItemsSource = $null
        Invoke-Async -Script {
            param($h, $ports, $timeout)
            $out = foreach ($p in $ports) {
                $sw = [System.Diagnostics.Stopwatch]::StartNew()
                $c = New-Object System.Net.Sockets.TcpClient
                $iar = $c.BeginConnect($h, $p, $null, $null)
                $ok = $iar.AsyncWaitHandle.WaitOne($timeout, $false)
                $sw.Stop()
                $note = ''
                if (-not $ok) { $c.Close(); $open = $false; $note = 'timeout' }
                else {
                    try { $c.EndConnect($iar); $open = $true } catch { $open = $false; $note = $_.Exception.Message }
                    $c.Close()
                }
                [pscustomobject]@{ Port=$p; Open=$open; TimeMs="$($sw.ElapsedMilliseconds) ms"; Note=$note }
            }
            return $out
        } -Arguments @($h, $ports, ([math]::Max(800, $script:Config.PingSweepTimeoutMs))) -OnComplete {
            param($r)
            Set-ButtonBusy -Button $portBtn -Busy $false
            $portData.ItemsSource = $r
            $open = @($r | Where-Object { $_.Open }).Count
            Show-Toast -Message "$open of $(@($r).Count) ports open on $h" -Kind Success
            Write-AuditLog -Action 'PortCheck' -Target $h -Details "$open open"
        }.GetNewClosure() -OnError {
            param($e)
            Set-ButtonBusy -Button $portBtn -Busy $false
            Show-Toast -Message "Check failed: $($e.Exception.Message)" -Kind Error
        }.GetNewClosure()
    }.GetNewClosure())
