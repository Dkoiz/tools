    [void]$safeStack.Children.Add($cbConfirm)
    $txtPingTimeout = New-Object System.Windows.Controls.TextBox; $txtPingTimeout.Width = 120
    $txtPingTimeout.Text = "$($script:Config.PingSweepTimeoutMs)"
    [void]$safeStack.Children.Add((New-LabeledRow -Label 'Ping timeout (ms)' -Field $txtPingTimeout))
    $txtPingThreads = New-Object System.Windows.Controls.TextBox; $txtPingThreads.Width = 120
    $txtPingThreads.Text = "$($script:Config.PingSweepMaxThreads)"
    [void]$safeStack.Children.Add((New-LabeledRow -Label 'Ping max threads' -Field $txtPingThreads))
    [void]$stack.Children.Add((New-Card -Child $safeStack))

    # --- Paths card ---
    $pathStack = New-Object System.Windows.Controls.StackPanel
    $pathH = New-Object System.Windows.Controls.TextBlock
    $pathH.Text = 'Paths'; $pathH.FontSize = 14; $pathH.FontWeight = 'SemiBold'; $pathH.Margin = '0,0,0,8'
    $pathH.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextBrush')
    [void]$pathStack.Children.Add($pathH)
    $pathInfo = New-Object System.Windows.Controls.TextBlock
    $pathInfo.Text = "Data dir: $($script:DataDir)`nConfig:   $($script:ConfigFile)`nAudit:    $($script:LogFile)"
    $pathInfo.FontFamily = 'Consolas'; $pathInfo.FontSize = 12
    $pathInfo.SetResourceReference([System.Windows.Controls.TextBlock]::ForegroundProperty, 'TextDim')
